---
import Layout from '@/layouts/Layout.astro'
import Section from '@/components/Section.astro'
import SectionHeading from '@/components/SectionHeading.astro'
import Button from '@/components/Button.astro'
import Calculator from '@/components/Calculator.astro'
import { Icon } from 'astro-icon/components'
import { models, woods, woodLabels, specs, comparatif, procedure, included, faq, modelImages } from '@/data/neotone'
import { site } from '@/data/site'
import { faqLdJson, productLdJson, breadcrumbLdJson } from '@/lib/ldJson'

const ld = [
  breadcrumbLdJson([
    { name: 'Accueil', url: '/' },
    { name: 'Le Neotone', url: '/le-neotone' },
  ]),
  faqLdJson(faq),
  productLdJson({ name: 'Neotone¹', description: 'Handpan numérique professionnel 10 notes', price: 1990, image: '/images/neotone-1-edition.webp' }),
  productLdJson({ name: 'Neotone¹ Mutant', description: 'Handpan numérique professionnel 19 notes avec écran LCD', price: 3150, image: '/images/neotone-mutant-edition.webp' }),
]
---

<Layout
  title="Le Neotone — meilleur handpan numérique | David Lesage"
  description="Le Neotone, accompagné par David Lesage : −5 % en ligne (−7 % au showroom), garantie 6 ans, calculateur de prix par pays et accompagnement humain de l’essai au déballage."
  ldJSON={ld}
>
  <!-- HERO -->
  <Section tone="ink" class="!py-20">
    <div class="grid items-center gap-10 lg:grid-cols-2">
      <div>
        <p class="text-xs font-700 uppercase tracking-[0.2em] text-gold">Le matériel · Handpan numérique</p>
        <h1 class="mt-4 font-display text-4xl font-700 leading-tight md:text-5xl">Le meilleur handpan numérique au monde</h1>
        <p class="mt-5 text-lg text-cream/80">En passant par moi, ambassadeur officiel Neotone, tu obtiens <strong class="text-cream">−5 % en ligne</strong> (ou <strong class="text-cream">−7 % au showroom</strong>), la <strong class="text-cream">garantie 6 ans</strong> et un accompagnement personnel — de l’essai jusqu’au déballage.</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <Button href="#calculateur" variant="primary">Calculer mon prix</Button>
          <Button href="/showroom" variant="light">Réserver ma venue au showroom</Button>
        </div>
      </div>
      <div class="overflow-hidden rounded-card bg-cream/5 p-8">
        <img src="/images/neotone-1-edition.webp" width="670" height="653" alt="Neotone¹, handpan numérique" class="mx-auto max-h-80 object-contain" loading="eager" />
      </div>
    </div>
  </Section>

  <!-- MODÈLES -->
  <Section id="modeles">
    <SectionHeading eyebrow="Les deux modèles" title="Choisis l’instrument qui te ressemble" intro="Toutes les gammes. Un seul instrument." />
    <div class="mt-12 grid gap-8 md:grid-cols-2">
      {models.map((m) => (
        <div class="flex flex-col overflow-hidden rounded-card border border-ink/10 bg-cream-deep/40">
          <div class="aspect-[4/3] bg-ink/5 p-6"><img src={modelImages[m.id].src} width={modelImages[m.id].w} height={modelImages[m.id].h} alt={m.label} class="h-full w-full object-contain" loading="lazy" /></div>
          <div class="flex flex-1 flex-col p-6">
            <div class="flex items-baseline justify-between">
              <h3 class="font-display text-2xl font-700">{m.label}</h3>
              <span class="rounded-full bg-copper/15 px-3 py-1 text-xs font-700 text-copper">{m.notesLabel}</span>
            </div>
            <p class="mt-1 text-ink-soft/80">{m.tagline}</p>
            <ul class="mt-4 flex-1 space-y-2 text-sm text-ink-soft/90">
              {m.features.map((f) => (
                <li class="flex gap-2"><Icon name="lucide:check" class="mt-0.5 h-4 w-4 shrink-0 text-copper" /> {f}</li>
              ))}
            </ul>
            <p class="mt-5 font-display text-lg font-700">À partir de {m.fromPrice.toLocaleString('fr-FR')} € HT</p>
          </div>
        </div>
      ))}
    </div>
  </Section>

  <!-- BOIS -->
  <Section tone="cream-deep" id="bois">
    <SectionHeading eyebrow="Les bois premium" title="Cinq essences, cinq caractères" intro="Le frêne naturel est inclus dans le prix de base. Quatre autres essences nobles sont disponibles en option." />
    <div class="mt-10 grid grid-cols-2 gap-4 md:grid-cols-5">
      {woods.map((w) => (
        <figure class="overflow-hidden rounded-card border border-ink/10 bg-cream">
          <img src={w.img} width="570" height="420" alt={`Bois ${woodLabels[w.key]}`} class="aspect-square w-full object-cover" loading="lazy" />
          <figcaption class="p-3 text-center">
            <p class="font-display font-700">{woodLabels[w.key]}</p>
            <p class="text-xs text-ink-soft/70">{w.supplement}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </Section>

  <!-- SOUS LA COQUE -->
  <Section id="technologie">
    <div class="grid items-center gap-10 lg:grid-cols-2">
      <div class="aspect-[4/3] overflow-hidden rounded-card"><img src="/images/interieur-1.webp" width="1080" height="1440" alt="Intérieur du Neotone, technologie de précision" class="h-full w-full object-cover" loading="lazy" /></div>
      <div>
        <SectionHeading align="left" eyebrow="Sous la coque" title="Une technologie de précision, assemblée à la main" />
        <p class="mt-5 text-lg text-ink-soft/90">Chaque Neotone¹ est conçu et assemblé artisanalement à Budapest. Sous le bois noble, des capteurs millimétriques détectent simultanément frappe, pression et position pour reproduire fidèlement la dynamique d’un handpan acoustique. Une électronique audio professionnelle — DAC 24 bits / 384 kHz, latence 5 ms, rapport signal/bruit 112 dB — en fait un instrument numérique sans compromis.</p>
      </div>
    </div>
    <h3 class="mt-16 text-center font-display text-2xl font-700">Spécifications techniques officielles</h3>
    <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {specs.map((s) => (
        <div class="rounded-card border border-ink/10 bg-cream-deep/40 p-6">
          <Icon name={s.icon} class="h-7 w-7 text-copper" />
          <h4 class="mt-3 font-display text-lg font-700">{s.title}</h4>
          <ul class="mt-3 space-y-1.5 text-sm text-ink-soft/85">
            {s.items.map((it) => <li>· {it}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </Section>

  <!-- SCÈNE & STUDIO -->
  <Section tone="ink">
    <SectionHeading tone="light" eyebrow="Scène & Studio" title="Le handpan numérique de référence" intro="Un seul handpan, une infinité de possibilités : le Neotone lève les contraintes de l’acoustique et ouvre un terrain de jeu inédit." />
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {[
        { t: 'Fini les galères de sonorisation', d: 'Plus de Larsen ni de difficulté à s’entendre. Un seul câble jack, une balance réglée en quelques secondes — et tu peux boucler ton jeu et brancher tes pédales.' },
        { t: 'Un studio dans l’instrument', d: 'Enregistreur intégré : maintiens le ding pour lancer une captation. Le son est pris à la source, en qualité studio, même en environnement bruyant.' },
        { t: 'Ta bulle, au casque', d: 'Branche un casque et joue sans déranger personne — la nuit, en appartement, en tournée. Une pureté sonore exceptionnelle.' },
      ].map((b) => (
        <div class="rounded-card border border-cream/10 bg-cream/5 p-6">
          <h3 class="font-display text-xl font-700 text-cream">{b.t}</h3>
          <p class="mt-3 text-cream/75">{b.d}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- COMPARATIF -->
  <Section id="comparatif">
    <SectionHeading eyebrow="Acoustique vs Neotone" title="Le handpan acoustique a ses limites — le Neotone les lève" intro="Ce que l’électronique change, concrètement." />
    <div class="mx-auto mt-10 max-w-4xl space-y-4">
      {comparatif.map((row) => (
        <div class="grid gap-px overflow-hidden rounded-card border border-ink/10 md:grid-cols-2">
          <div class="flex gap-3 bg-cream-deep/60 p-5"><Icon name="lucide:x" class="mt-0.5 h-5 w-5 shrink-0 text-rust" /><p class="text-sm text-ink-soft/85">{row.aco}</p></div>
          <div class="flex gap-3 bg-copper/10 p-5"><Icon name="lucide:check" class="mt-0.5 h-5 w-5 shrink-0 text-copper" /><p class="text-sm font-600 text-ink">{row.neo}</p></div>
        </div>
      ))}
    </div>
  </Section>

  <!-- CALCULATEUR -->
  <Section tone="cream-deep" id="calculateur">
    <SectionHeading eyebrow="Calculateur de prix" title="Combien va vraiment me coûter mon Neotone ?" intro="Choisis ton mode d’achat, ton modèle, ton bois et ton pays — le calculateur applique la bonne remise et la TVA 2026." />
    <div class="mt-10"><Calculator /></div>
    <p class="mx-auto mt-6 max-w-3xl text-center text-xs text-ink-soft/70">Les prix publics affichés incluent déjà l’envoi mondial. Taux de TVA standards 2026. Hors UE : aucune TVA UE appliquée, mais des frais de douane locaux peuvent s’ajouter à la livraison, à ta charge.</p>
  </Section>

  <!-- PROCÉDURE -->
  <Section id="procedure">
    <SectionHeading eyebrow="Procédure d’achat" title="De ta première question à la réception" intro="Un parcours simple et transparent, accompagné de bout en bout. Au showroom, tu repars avec ton instrument le jour même." />
    <ol class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {procedure.map((step) => (
        <li class="rounded-card border border-ink/10 bg-cream-deep/40 p-6">
          <span class="grid h-9 w-9 place-items-center rounded-full bg-rust font-display text-lg font-700 text-cream">{step.n}</span>
          <h3 class="mt-4 font-display text-lg font-700">{step.title}</h3>
          <p class="mt-2 text-sm text-ink-soft/85">{step.text}</p>
        </li>
      ))}
    </ol>
  </Section>

  <!-- CE QUI EST INCLUS -->
  <Section tone="cream-deep">
    <SectionHeading eyebrow="Tout inclus dans le prix" title="Ce que tu reçois" />
    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {included.map((i) => (
        <div class="rounded-card border border-ink/10 bg-cream p-6 text-center">
          <Icon name={i.icon} class="mx-auto h-8 w-8 text-copper" />
          <h3 class="mt-3 font-display text-lg font-700">{i.title}</h3>
          <p class="mt-2 text-sm text-ink-soft/85">{i.text}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- FAQ -->
  <Section id="faq">
    <SectionHeading eyebrow="FAQ" title="Toutes les réponses avant de te lancer" />
    <div class="mx-auto mt-10 max-w-3xl space-y-3">
      {faq.map((item) => (
        <details class="group rounded-card border border-ink/10 bg-cream-deep/40 p-5">
          <summary class="flex cursor-pointer items-center justify-between gap-4 font-display text-lg font-600 marker:content-none">
            {item.q}
            <Icon name="lucide:chevron-down" class="h-5 w-5 shrink-0 text-copper transition-transform group-open:rotate-180" />
          </summary>
          <p class="mt-3 text-ink-soft/85">{item.a}</p>
        </details>
      ))}
    </div>
    <p class="mt-8 text-center text-ink-soft/85">As-tu d’autres questions ? Écris-moi à <a href={`mailto:${site.emailNeotone}`} class="font-700 text-rust underline">{site.emailNeotone}</a></p>
  </Section>
</Layout>
