---
// Formulaire de réservation / demande de contact.
// Remplace les anciens liens mailto : la demande est ENREGISTRÉE dans Supabase
// (table site_leads) avec sa raison (`source`), puis David reçoit une notification
// et la personne un accusé de réception.
//
// S'ouvre en modale au clic sur n'importe quel élément [data-booking="<source>"].
// Inclure UNE fois par page contenant de tels boutons.
import { getDict } from '@/i18n/dict'
import type { Lang } from '@/i18n/config'

interface Props { lang: Lang }
const { lang } = Astro.props
const bk = getDict(lang).booking
---

<div
  id="booking-modal"
  class="fixed inset-0 z-[100] hidden items-start justify-center overflow-y-auto bg-ink/80 p-4 py-10 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
>
  <div class="relative w-full max-w-lg rounded-card bg-cream p-6 shadow-2xl md:p-8">
    <button class="bk-close absolute right-4 top-4 grid h-9 w-9 place-items-center rounded-full text-2xl leading-none text-ink-soft hover:bg-ink/5" type="button" aria-label={bk.close}>×</button>

    <h2 class="pr-8 font-display text-2xl font-700" data-bk-title>{bk.defaultTitle}</h2>
    <p class="mt-2 text-sm text-ink-soft/85" data-bk-intro>{bk.defaultIntro}</p>

    <form id="booking-form" class="mt-5 grid gap-3" data-lang={lang} novalidate>
      <input type="hidden" name="source" value="showroom-visit" />
      <input type="hidden" name="eventDate" value="" />

      <div class="grid gap-3 sm:grid-cols-2">
        <label class="block">
          <span class="text-sm font-600">{bk.first}</span>
          <input type="text" name="firstName" autocomplete="given-name" required class="mt-1 w-full rounded-xl border border-ink/20 bg-cream-deep/30 px-4 py-3 focus:border-copper focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-sm font-600">{bk.last}</span>
          <input type="text" name="lastName" autocomplete="family-name" required class="mt-1 w-full rounded-xl border border-ink/20 bg-cream-deep/30 px-4 py-3 focus:border-copper focus:outline-none" />
        </label>
      </div>

      <div class="grid gap-3 sm:grid-cols-2">
        <label class="block">
          <span class="text-sm font-600">{bk.email}</span>
          <input type="email" name="email" autocomplete="email" required class="mt-1 w-full rounded-xl border border-ink/20 bg-cream-deep/30 px-4 py-3 focus:border-copper focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-sm font-600">{bk.phone}</span>
          <input type="tel" name="phone" autocomplete="tel" class="mt-1 w-full rounded-xl border border-ink/20 bg-cream-deep/30 px-4 py-3 focus:border-copper focus:outline-none" />
        </label>
      </div>

      <label class="block" data-bk-people>
        <span class="text-sm font-600">{bk.people}</span>
        <input type="number" name="peopleCount" min="1" max="20" value="1" class="mt-1 w-full rounded-xl border border-ink/20 bg-cream-deep/30 px-4 py-3 focus:border-copper focus:outline-none" />
      </label>

      <label class="block">
        <span class="text-sm font-600">{bk.message}</span>
        <textarea name="message" rows="3" placeholder={bk.messagePlaceholder} class="mt-1 w-full rounded-xl border border-ink/20 bg-cream-deep/30 px-4 py-3 focus:border-copper focus:outline-none"></textarea>
      </label>

      <button type="submit" data-sending={bk.sending} class="mt-1 rounded-full bg-rust px-6 py-3.5 font-700 text-cream shadow-sm transition-colors hover:bg-copper disabled:opacity-60">{bk.submit}</button>
      <p data-bk-error class="hidden text-sm font-600 text-rust">{bk.error}</p>
      <p class="text-xs text-ink-soft/70">{bk.privacy}</p>
    </form>

    <div data-bk-success class="hidden py-6 text-center">
      <p class="font-display text-xl font-700 text-ink">{bk.successTitle}</p>
      <p class="mt-3 text-ink-soft/85">{bk.successText}</p>
      <button type="button" class="bk-close mt-6 rounded-full bg-rust px-6 py-3 font-700 text-cream hover:bg-copper">{bk.successClose}</button>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('booking-modal')
  const form = document.getElementById('booking-form') as HTMLFormElement | null
  const success = modal?.querySelector('[data-bk-success]') as HTMLElement
  const titleEl = modal?.querySelector('[data-bk-title]') as HTMLElement
  const introEl = modal?.querySelector('[data-bk-intro]') as HTMLElement
  const peopleEl = modal?.querySelector('[data-bk-people]') as HTMLElement
  const errEl = modal?.querySelector('[data-bk-error]') as HTMLElement
  let lastFocused: HTMLElement | null = null

  function open(trigger: HTMLElement) {
    if (!modal || !form) return
    lastFocused = document.activeElement as HTMLElement
    const source = trigger.getAttribute('data-booking') || 'showroom-visit'
    ;(form.elements.namedItem('source') as HTMLInputElement).value = source
    ;(form.elements.namedItem('eventDate') as HTMLInputElement).value = trigger.getAttribute('data-event-date') || ''
    if (titleEl) titleEl.textContent = trigger.getAttribute('data-title') || titleEl.textContent
    if (introEl) introEl.textContent = trigger.getAttribute('data-intro') || introEl.textContent
    // Le nombre de personnes n'a de sens que pour une réservation d'événement.
    if (peopleEl) peopleEl.classList.toggle('hidden', source !== 'showcase-booking')
    form.classList.remove('hidden')
    success?.classList.add('hidden')
    errEl?.classList.add('hidden')
    modal.classList.remove('hidden')
    modal.classList.add('flex')
    modal.setAttribute('aria-hidden', 'false')
    document.body.style.overflow = 'hidden'
  }

  function close() {
    if (!modal) return
    modal.classList.add('hidden')
    modal.classList.remove('flex')
    modal.setAttribute('aria-hidden', 'true')
    document.body.style.overflow = ''
    if (lastFocused?.focus) lastFocused.focus()
  }

  document.querySelectorAll<HTMLElement>('[data-booking]').forEach((el) => {
    el.addEventListener('click', (e) => { e.preventDefault(); open(el) })
  })
  modal?.querySelectorAll('.bk-close').forEach((b) => b.addEventListener('click', close))
  modal?.addEventListener('click', (e) => { if (e.target === modal) close() })
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) close()
  })

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    if (!form.reportValidity()) return
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement
    const data = new FormData(form)
    const get = (k: string) => String(data.get(k) || '').trim()
    const label = btn.textContent
    btn.disabled = true
    btn.textContent = btn.getAttribute('data-sending') || '…'
    errEl?.classList.add('hidden')

    try {
      const r = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          firstName: get('firstName'),
          lastName: get('lastName'),
          email: get('email'),
          phone: get('phone'),
          message: get('message'),
          peopleCount: get('peopleCount') ? Number(get('peopleCount')) : null,
          eventDate: get('eventDate') || null,
          source: get('source'),
          lang: form.dataset.lang || 'fr',
          page: location.pathname,
        }),
      })
      if (!r.ok) throw new Error('failed')
      form.classList.add('hidden')
      success?.classList.remove('hidden')
    } catch {
      errEl?.classList.remove('hidden')
    } finally {
      btn.disabled = false
      btn.textContent = label
    }
  })
</script>
