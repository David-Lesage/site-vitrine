---
// Encadré affiché tant que `site.appPublicAccess` est à false : explique que
// l'application est en bêta fermée et recueille les inscriptions.
// Ancre #acces — c'est la cible de tous les anciens boutons « ouvrir l'app ».
// Un SEUL appel à l'action : le formulaire (le champ « motivation » remplace
// l'ancien lien mailto de candidature bêta-testeur).
import { Icon } from 'astro-icon/components'
import { getDict } from '@/i18n/dict'
import type { Lang } from '@/i18n/config'

interface Props { lang: Lang }
const { lang } = Astro.props
const b = getDict(lang).common.beta
---

<div id="acces" class="mx-auto max-w-3xl scroll-mt-28 rounded-card border border-copper/30 bg-copper/5 p-6 md:p-8">
  <span class="inline-flex items-center gap-2 rounded-full bg-copper/15 px-3 py-1 text-xs font-700 uppercase tracking-widest text-copper">
    <Icon name="lucide:lock" class="h-3.5 w-3.5" />{b.badge}
  </span>
  <h2 class="mt-4 font-display text-2xl font-700 text-ink">{b.title}</h2>
  <p class="mt-3 text-ink-soft/90">{b.text}</p>
  <p class="mt-3 text-ink-soft/90">{b.wish}</p>
  <div class="mt-8 rounded-card border border-ink/10 bg-cream p-5 md:p-6">
    <h3 class="font-display text-lg font-700">{b.formTitle}</h3>
    <form id="beta-form" class="mt-4 grid gap-3" data-lang={lang} data-redirect={lang === 'en' ? '/en/blog' : '/blog'} novalidate>
      <div class="grid gap-3 sm:grid-cols-2">
        <label class="block">
          <span class="text-sm font-600">{b.formFirst}</span>
          <input type="text" name="firstName" autocomplete="given-name" required class="mt-1 w-full rounded-xl border border-ink/20 bg-cream-deep/30 px-4 py-3 focus:border-copper focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-sm font-600">{b.formLast}</span>
          <input type="text" name="lastName" autocomplete="family-name" required class="mt-1 w-full rounded-xl border border-ink/20 bg-cream-deep/30 px-4 py-3 focus:border-copper focus:outline-none" />
        </label>
      </div>
      <label class="block">
        <span class="text-sm font-600">{b.formEmail}</span>
        <input type="email" name="email" autocomplete="email" required class="mt-1 w-full rounded-xl border border-ink/20 bg-cream-deep/30 px-4 py-3 focus:border-copper focus:outline-none" />
      </label>
      <fieldset class="mt-2">
        <legend class="text-sm font-600">{b.formHandpan}</legend>
        <div class="mt-2 flex flex-wrap gap-2">
          {[['yes', b.formHandpanYes], ['no', b.formHandpanNo], ['planning', b.formHandpanPlanning]].map(([v, label]) => (
            <label class="cursor-pointer">
              <input type="radio" name="hasHandpan" value={v} required class="peer sr-only" />
              <span class="inline-block rounded-full border border-ink/20 px-4 py-2 text-sm transition-colors peer-checked:border-rust peer-checked:bg-rust peer-checked:text-cream hover:bg-ink/5">{label}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <!-- Sous-question : visible + obligatoire uniquement si « Oui » -->
      <fieldset data-sub="handpanType" class="ml-0 hidden border-l-2 border-copper/30 pl-4 sm:ml-2">
        <legend class="text-sm font-600">{b.formHandpanType}</legend>
        <div class="mt-2 flex flex-wrap gap-2">
          {[['acoustic', b.formHandpanTypeAcoustic], ['electronic', b.formHandpanTypeElectronic], ['both', b.formHandpanTypeBoth]].map(([v, label]) => (
            <label class="cursor-pointer">
              <input type="radio" name="handpanType" value={v} class="peer sr-only" />
              <span class="inline-block rounded-full border border-ink/20 px-4 py-2 text-sm transition-colors peer-checked:border-rust peer-checked:bg-rust peer-checked:text-cream hover:bg-ink/5">{label}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <fieldset class="mt-2">
        <legend class="text-sm font-600">{b.formUsage}</legend>
        <div class="mt-2 flex flex-wrap gap-2">
          {[['personal', b.formUsagePersonal], ['teacher', b.formUsageTeacher], ['both', b.formUsageBoth], ['maker', b.formUsageMaker]].map(([v, label]) => (
            <label class="cursor-pointer">
              <input type="radio" name="usageType" value={v} required class="peer sr-only" />
              <span class="inline-block rounded-full border border-ink/20 px-4 py-2 text-sm transition-colors peer-checked:border-rust peer-checked:bg-rust peer-checked:text-cream hover:bg-ink/5">{label}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <!-- Sous-question : visible + obligatoire uniquement si « À titre personnel » -->
      <fieldset data-sub="personalGoal" class="ml-0 hidden border-l-2 border-copper/30 pl-4 sm:ml-2">
        <legend class="text-sm font-600">{b.formPersonalGoal}</legend>
        <div class="mt-2 flex flex-wrap gap-2">
          {[['learn', b.formPersonalGoalLearn], ['compose', b.formPersonalGoalCompose]].map(([v, label]) => (
            <label class="cursor-pointer">
              <input type="radio" name="personalGoal" value={v} class="peer sr-only" />
              <span class="inline-block rounded-full border border-ink/20 px-4 py-2 text-sm transition-colors peer-checked:border-rust peer-checked:bg-rust peer-checked:text-cream hover:bg-ink/5">{label}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <label class="mt-2 flex cursor-pointer items-start gap-3 rounded-xl border border-copper/25 bg-copper/5 p-4">
        <input type="checkbox" name="wantsBeta" class="mt-0.5 h-5 w-5 shrink-0 accent-rust" />
        <span class="text-sm text-ink-soft/90">{b.formBeta}</span>
      </label>

      <label class="mt-2 block">
        <span data-motivation-label class="text-sm font-600" data-label-default={b.formMotivation} data-label-beta={b.formMotivationBeta}>{b.formMotivation}</span>
        <span class="mt-1 block text-xs text-ink-soft/70">{b.formMotivationHint}</span>
        <textarea name="motivation" rows="3" placeholder={b.formMotivationPlaceholder} class="mt-2 w-full rounded-xl border border-ink/20 bg-cream-deep/30 px-4 py-3 focus:border-copper focus:outline-none"></textarea>
      </label>

      <label class="mt-1 flex cursor-pointer items-start gap-3 rounded-xl border border-ink/10 bg-cream-deep/30 p-4">
        <input type="checkbox" name="wantsShowcase" class="mt-0.5 h-5 w-5 shrink-0 accent-rust" />
        <span class="text-sm text-ink-soft/90">{b.formShowcase}</span>
      </label>

      <button type="submit" data-sending={b.formSending} class="mt-1 rounded-full bg-rust px-6 py-3.5 font-700 text-cream shadow-sm transition-colors hover:bg-copper disabled:opacity-60">{b.formSubmit}</button>
      <p data-beta-error class="hidden text-sm font-600 text-rust">{b.formError}</p>
      <p class="text-xs text-ink-soft/70">{b.formPrivacy}</p>
    </form>
  </div>
</div>

<script>
  const form = document.getElementById('beta-form') as HTMLFormElement | null

  // ---- Sous-questions conditionnelles ---------------------------------
  // Une sous-question masquée ne doit JAMAIS rester `required` (le navigateur
  // refuserait de valider un champ invisible).
  const sub = (name: string) => form?.querySelector(`[data-sub="${name}"]`) as HTMLFieldSetElement | null
  const radios = (name: string) => Array.from(form?.querySelectorAll(`input[name="${name}"]`) || []) as HTMLInputElement[]
  const checked = (name: string) => radios(name).find((r) => r.checked)?.value || ''

  function toggleSub(name: string, show: boolean) {
    const fs = sub(name)
    if (!fs) return
    fs.classList.toggle('hidden', !show)
    radios(name).forEach((r) => {
      r.required = show
      if (!show) r.checked = false
    })
  }

  function syncConditionals() {
    toggleSub('handpanType', checked('hasHandpan') === 'yes')
    toggleSub('personalGoal', checked('usageType') === 'personal')
    // Motivation obligatoire dès que la personne veut devenir bêta-testeur.
    const wantsBeta = (form?.querySelector('input[name="wantsBeta"]') as HTMLInputElement | null)?.checked === true
    const motivation = form?.querySelector('textarea[name="motivation"]') as HTMLTextAreaElement | null
    if (motivation) motivation.required = wantsBeta
    const label = form?.querySelector('[data-motivation-label]') as HTMLElement | null
    if (label) label.textContent = (wantsBeta ? label.dataset.labelBeta : label.dataset.labelDefault) || label.textContent
  }

  form?.addEventListener('change', syncConditionals)
  syncConditionals()

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement
    const err = form.querySelector('[data-beta-error]') as HTMLElement
    const data = new FormData(form)
    const get = (k: string) => String(data.get(k) || '').trim()
    if (!get('email') || !form.reportValidity()) return

    const label = btn.textContent
    btn.disabled = true
    btn.textContent = btn.getAttribute('data-sending') || '…'
    err.classList.add('hidden')

    try {
      const r = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          firstName: get('firstName'),
          lastName: get('lastName'),
          email: get('email'),
          hasHandpan: get('hasHandpan'),
          handpanType: get('handpanType'),
          usageType: get('usageType'),
          personalGoal: get('personalGoal'),
          motivation: get('motivation'),
          wantsBeta: data.get('wantsBeta') !== null,
          wantsShowcase: data.get('wantsShowcase') !== null,
          source: 'beta-waitlist',
          lang: form.dataset.lang || 'fr',
          page: location.pathname,
        }),
      })
      if (!r.ok) throw new Error('failed')
      // Inscription enregistrée → on emmène la personne découvrir l'app.
      window.location.href = form.dataset.redirect || '/blog'
    } catch {
      err.classList.remove('hidden')
      btn.disabled = false
      btn.textContent = label
    }
  })
</script>
