---
interface Props {
  id?: string
  class?: string
  tone?: 'cream' | 'cream-deep' | 'ink'
  width?: 'default' | 'narrow' | 'wide'
  /** Attributs libres (ex. data-when="open") posés sur le <section>. */
  [key: string]: unknown
}
const { id, class: cls = '', tone = 'cream', width = 'default', ...rest } = Astro.props
const toneCls = {
  cream: 'bg-cream text-ink',
  'cream-deep': 'bg-cream-deep text-ink',
  ink: 'bg-ink text-cream',
}[tone]
const widthCls = {
  default: 'max-w-7xl',
  narrow: 'max-w-3xl',
  wide: 'max-w-screen-2xl',
}[width]
---

<section id={id} class:list={['scroll-mt-24', toneCls]} {...rest}>
  <div class:list={['mx-auto px-4 py-16 lg:px-8 lg:py-24', widthCls, cls]}>
    <slot />
  </div>
</section>
