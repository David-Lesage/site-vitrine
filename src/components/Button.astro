---
interface Props {
  href: string
  variant?: 'primary' | 'secondary' | 'ghost' | 'light'
  class?: string
  external?: boolean
}
const { href, variant = 'primary', class: cls = '', external = false } = Astro.props
const base = 'inline-flex items-center justify-center gap-2 rounded-full px-6 py-3 text-sm font-700 transition-all duration-200 hover:-translate-y-0.5'
const variants = {
  primary: 'bg-rust text-cream shadow-md hover:bg-copper',
  secondary: 'bg-ink text-cream shadow-md hover:bg-ink-soft',
  ghost: 'border border-ink/20 text-ink hover:bg-ink/5',
  light: 'bg-cream text-ink shadow-md hover:bg-cream-deep',
}
const attrs = external ? { target: '_blank', rel: 'noopener' } : {}
---

<a href={href} class:list={[base, variants[variant], cls]} {...attrs}>
  <slot />
</a>
