---
interface Props {
  eyebrow?: string
  title: string
  intro?: string
  align?: 'left' | 'center'
  tone?: 'dark' | 'light'
  level?: 1 | 2
}
const { eyebrow, title, intro, align = 'center', tone = 'dark', level = 2 } = Astro.props
const alignCls = align === 'center' ? 'mx-auto text-center' : 'text-left'
const introColor = tone === 'light' ? 'text-cream/75' : 'text-ink-soft/85'
const eyebrowColor = tone === 'light' ? 'text-gold' : 'text-copper'
const Heading = level === 1 ? 'h1' : 'h2'
---

<div class:list={['max-w-2xl', alignCls]}>
  {eyebrow && <p class:list={['text-xs font-700 uppercase tracking-[0.2em]', eyebrowColor]}>{eyebrow}</p>}
  <Heading class="mt-3 font-display text-3xl font-700 leading-tight md:text-4xl">
    <Fragment set:html={title} />
  </Heading>
  {intro && <p class:list={['mt-4 text-lg leading-relaxed', introColor]}><Fragment set:html={intro} /></p>}
</div>
