---
import { nav, footerNav, site } from '@/data/site'
import { getDict } from '@/i18n/dict'
import { localizePath } from '@/i18n/utils'
import type { Lang } from '@/i18n/config'

interface Props {
  lang: Lang
}
const { lang } = Astro.props
const t = getDict(lang)
const year = new Date().getFullYear()
const navLabel = (key: string) => (t.common.nav as Record<string, string>)[key]
const footLabel = (key: string) => (t.common.footer as Record<string, string>)[key]
---

<footer class="mt-24 border-t border-ink/10 bg-ink text-cream/90">
  <div class="chroma-bar h-1 w-full"></div>
  <div class="mx-auto grid max-w-7xl gap-10 px-4 py-14 lg:grid-cols-4 lg:px-8">
    <div class="lg:col-span-1">
      <p class="font-display text-2xl font-700 text-cream">David Lesage</p>
      <p class="mt-3 max-w-xs text-sm text-cream/70">{t.common.tagline}</p>
      <div class="mt-5 flex gap-3">
        <a href={site.social.instagram} class="hover:text-gold" rel="noopener" target="_blank">Instagram</a>
        <a href={site.social.youtube} class="hover:text-gold" rel="noopener" target="_blank">YouTube</a>
      </div>
    </div>

    <nav class="lg:col-span-1" aria-label={footLabel('navigation')}>
      <p class="text-xs font-700 uppercase tracking-widest text-gold">{footLabel('navigation')}</p>
      <ul class="mt-4 space-y-2 text-sm">
        {nav.map((item) => (
          <li><a href={localizePath(item.href, lang)} class="text-cream/75 hover:text-cream">{navLabel(item.key)}</a></li>
        ))}
      </ul>
    </nav>

    <nav class="lg:col-span-1" aria-label={footLabel('resources')}>
      <p class="text-xs font-700 uppercase tracking-widest text-gold">{footLabel('resources')}</p>
      <ul class="mt-4 space-y-2 text-sm">
        {footerNav.map((item) => (
          <li><a href={localizePath(item.href, lang)} class="text-cream/75 hover:text-cream">{footLabel(item.key)}</a></li>
        ))}
      </ul>
    </nav>

    <div class="lg:col-span-1">
      <p class="text-xs font-700 uppercase tracking-widest text-gold">{footLabel('contact')}</p>
      <ul class="mt-4 space-y-2 text-sm text-cream/75">
        <li><a href={`mailto:${site.email}`} class="hover:text-cream">{site.email}</a></li>
        <li><a href={`tel:${site.phoneHref}`} class="hover:text-cream">{site.phone}</a></li>
        <li>{site.address}</li>
      </ul>
    </div>
  </div>

  <div class="border-t border-cream/10 px-4 py-6 text-center text-xs text-cream/50 lg:px-8">
    © {year} · David Lesage · {footLabel('rights')}
  </div>
</footer>
