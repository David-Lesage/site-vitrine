---
import { nav, footerNav, site } from '@/data/site'
const year = new Date().getFullYear()
---

<footer class="mt-24 border-t border-ink/10 bg-ink text-cream/90">
  <div class="chroma-bar h-1 w-full"></div>
  <div class="mx-auto grid max-w-7xl gap-10 px-4 py-14 lg:grid-cols-4 lg:px-8">
    <div class="lg:col-span-1">
      <p class="font-display text-2xl font-700 text-cream">David Lesage</p>
      <p class="mt-3 max-w-xs text-sm text-cream/70">{site.tagline}</p>
      <div class="mt-5 flex gap-3">
        <a href={site.social.instagram} class="hover:text-gold" aria-label="Instagram" rel="noopener" target="_blank">Instagram</a>
        <a href={site.social.youtube} class="hover:text-gold" aria-label="YouTube" rel="noopener" target="_blank">YouTube</a>
      </div>
    </div>

    <nav class="lg:col-span-1" aria-label="Plan du site">
      <p class="text-xs font-700 uppercase tracking-widest text-gold">Navigation</p>
      <ul class="mt-4 space-y-2 text-sm">
        {nav.map((item) => (
          <li><a href={item.href} class="text-cream/75 hover:text-cream">{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <nav class="lg:col-span-1" aria-label="Ressources">
      <p class="text-xs font-700 uppercase tracking-widest text-gold">Ressources</p>
      <ul class="mt-4 space-y-2 text-sm">
        {footerNav.map((item) => (
          <li><a href={item.href} class="text-cream/75 hover:text-cream">{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="lg:col-span-1">
      <p class="text-xs font-700 uppercase tracking-widest text-gold">Contact</p>
      <ul class="mt-4 space-y-2 text-sm text-cream/75">
        <li><a href={`mailto:${site.email}`} class="hover:text-cream">{site.email}</a></li>
        <li><a href={`tel:${site.phoneHref}`} class="hover:text-cream">{site.phone}</a></li>
        <li>{site.address}</li>
      </ul>
    </div>
  </div>

  <div class="border-t border-cream/10 px-4 py-6 text-center text-xs text-cream/50 lg:px-8">
    © {year} · David Lesage · Ambassadeur indépendant Neotone · Tous les prix sont indicatifs et peuvent évoluer sans préavis.
  </div>
</footer>
