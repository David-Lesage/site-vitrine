---
// Grille de contributions (gratuit + mensuel / annuel / à vie).
// Montants figés au build depuis Stripe, puis rafraîchis en direct côté client.
import Button from '@/components/Button.astro'
import { site } from '@/data/site'
import { getDict } from '@/i18n/dict'
import { formatAmount, fetchPricesAtBuild, SUPABASE_ANON_KEY, GET_PRICES_URL, type PlanId } from '@/lib/prices'
import type { Lang } from '@/i18n/config'

interface Props { lang: Lang }
const { lang } = Astro.props
const t = getDict(lang).studio
const locale = lang === 'en' ? 'en-GB' : 'fr-FR'

const prices = await fetchPricesAtBuild()
const period: Record<PlanId, string> = { monthly: t.pricePerMonth, annual: t.pricePerYear, lifetime: t.priceOnce }
const badge: Record<PlanId, string | null> = { monthly: null, annual: t.pricePopular, lifetime: t.priceMax }
const tiers: PlanId[] = ['monthly', 'annual', 'lifetime']
const signupUrl = site.appUrl + '?signup=1'
---

<div class="grid gap-6 lg:grid-cols-4">
  <!-- Palier gratuit -->
  <div class="flex flex-col rounded-card border border-ink/10 bg-cream-deep/40 p-6">
    <h3 class="font-display text-xl font-700">{t.priceFree.name}</h3>
    <p class="mt-3 font-display text-3xl font-700">{t.priceFree.price}</p>
    <p class="mt-3 flex-1 text-sm text-ink-soft/85">{t.priceFree.blurb}</p>
    <div class="mt-6"><Button href={signupUrl} external variant="ghost" class="w-full justify-center">{t.priceFreeCta}</Button></div>
  </div>

  <!-- Contributions -->
  {tiers.map((plan) => (
    <div class:list={['relative flex flex-col rounded-card border p-6', plan === 'annual' ? 'border-copper bg-cream shadow-sm' : 'border-ink/10 bg-cream-deep/40']}>
      {badge[plan] && <span class="absolute -top-3 left-6 rounded-full bg-rust px-3 py-1 text-xs font-700 text-cream">{badge[plan]}</span>}
      <h3 class="font-display text-xl font-700">{t.priceTiers[plan].name}</h3>
      <p class="mt-3 font-display text-3xl font-700">
        <span class="price-amount" data-plan={plan}>{formatAmount(prices[plan], locale)}</span>
        <span class="text-base font-600 text-ink-soft/70"> {period[plan]}</span>
      </p>
      <p class="mt-3 flex-1 text-sm text-ink-soft/85">{t.priceTiers[plan].blurb}</p>
      <a href={signupUrl} target="_blank" rel="noopener" class="mt-6 block w-full rounded-full bg-rust px-5 py-3 text-center font-700 text-cream transition-colors hover:bg-copper">{t.priceCta}</a>
    </div>
  ))}
</div>
<p class="mt-6 text-center text-xs text-ink-soft/65">{t.priceNote}</p>

<script define:vars={{ url: GET_PRICES_URL, key: SUPABASE_ANON_KEY, locale }}>
  // Rafraîchit les montants en direct depuis Stripe (actif dès que l'origine
  // du site est autorisée côté CORS de l'Edge Function). Échec silencieux.
  ;(async () => {
    try {
      const res = await fetch(url, {
        method: 'POST',
        headers: { apikey: key, Authorization: 'Bearer ' + key, 'Content-Type': 'application/json' },
        body: '{}',
      })
      if (!res.ok) return
      const data = await res.json()
      const fmt = (p) => {
        if (!p || p.amount == null) return null
        const sym = p.currency === 'eur' ? '€' : p.currency === 'usd' ? '$' : (p.currency || '').toUpperCase()
        const n = Number.isInteger(p.amount) ? p.amount.toLocaleString(locale) : p.amount.toLocaleString(locale, { minimumFractionDigits: 2 })
        return n + ' ' + sym
      }
      document.querySelectorAll('.price-amount[data-plan]').forEach((el) => {
        const plan = el.getAttribute('data-plan')
        const label = fmt(data[plan])
        if (label) el.textContent = label
      })
    } catch {
      /* CORS / réseau : on garde les montants figés au build */
    }
  })()
</script>
