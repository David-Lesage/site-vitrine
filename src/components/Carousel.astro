---
// Carrousel d'images avec navigation, points, démo automatique et ouverture
// en plein écran (lightbox). Inclure <Lightbox /> une fois par page.
interface Slide { src: string; wide?: boolean }
interface Props { id: string; slides: Slide[]; alt: string }
const { id, slides, alt } = Astro.props
const total = slides.length
---

<div class="model-photo relative">
  <button class="carousel-btn carousel-prev" type="button" aria-label="Photo précédente">‹</button>
  <div class="carousel" data-carousel={id}>
    <div class="carousel-track">
      {slides.map((s, i) => (
        <div class:list={['carousel-slide', s.wide && 'is-wide']}>
          <img src={s.src} alt={`${alt} — ${i + 1}`} loading="lazy" />
        </div>
      ))}
    </div>
    <div class="carousel-counter">1 / {total}</div>
    <div class="carousel-dots" role="tablist" aria-label={`Photos ${alt}`}>
      {slides.map((_, i) => (
        <button class:list={['carousel-dot', i === 0 && 'is-active']} type="button" data-slide={i} aria-label={`Photo ${i + 1}`}></button>
      ))}
    </div>
  </div>
  <button class="carousel-btn carousel-next" type="button" aria-label="Photo suivante">›</button>
</div>
