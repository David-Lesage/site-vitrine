---
import Layout from '@/layouts/Layout.astro'
import Section from '@/components/Section.astro'
import SectionHeading from '@/components/SectionHeading.astro'
import Button from '@/components/Button.astro'
import VideoGrid from '@/components/VideoGrid.astro'
import { Icon } from 'astro-icon/components'
import { chromaKeys, site, studioVideos } from '@/data/site'
import { getDict } from '@/i18n/dict'
import { localizePath } from '@/i18n/utils'
import type { Lang } from '@/i18n/config'

interface Props { lang: Lang }
const { lang } = Astro.props
const t = getDict(lang)
const st = t.studio
const L = (p: string) => localizePath(p, lang)
const emotions = t.common.emotions
const modeImgs = [
  { img: '/images/app-logique.webp', w: 1100, h: 1327 },
  { img: '/images/app-atlas.webp', w: 1100, h: 1202 },
  { img: '/images/app-creation.webp', w: 1100, h: 1109 },
  { img: '/images/app-midi.webp', w: 1100, h: 1041 },
]
const constelImgs = [
  { img: '/images/constel-polygone-thumb.webp', w: 1047, h: 963 },
  { img: '/images/constel-ouvert-thumb.webp', w: 1045, h: 944 },
  { img: '/images/constel-mains-thumb.webp', w: 1020, h: 954 },
]
---

<Layout title={st.title} description={st.description}>
  <section class="relative overflow-hidden bg-ink text-cream">
    <div class="chroma-bar absolute inset-x-0 top-0 h-1.5"></div>
    <div class="mx-auto max-w-4xl px-4 py-24 text-center lg:py-28">
      <p class="text-xs font-700 uppercase tracking-[0.2em] text-gold">{st.heroEyebrow}</p>
      <h1 class="mt-5 font-display text-4xl font-700 leading-tight md:text-6xl">{st.heroTitleA}<br /><span class="text-gradient-brand">{st.heroTitleB}</span></h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-cream/80">{st.heroLead}</p>
      <div class="mt-9"><Button href={site.appUrl + '?signup=1'} external variant="primary">{st.ctaOpen}</Button></div>
    </div>
  </section>

  <Section>
    <SectionHeading eyebrow={st.problemEyebrow} title={st.problemTitle} />
    <div class="mt-10 grid gap-6 md:grid-cols-2">
      <div class="rounded-card border border-ink/10 bg-cream-deep/40 p-6"><span class="font-display text-3xl font-700 text-copper">01</span><h3 class="mt-2 font-display text-xl font-700">{st.problem1Title}</h3><p class="mt-2 text-ink-soft/85">{st.problem1Text}</p></div>
      <div class="rounded-card border border-ink/10 bg-cream-deep/40 p-6"><span class="font-display text-3xl font-700 text-copper">02</span><h3 class="mt-2 font-display text-xl font-700">{st.problem2Title}</h3><p class="mt-2 text-ink-soft/85">{st.problem2Text}</p></div>
    </div>
  </Section>

  <Section tone="ink">
    <SectionHeading tone="light" eyebrow={st.chromaEyebrow} title={st.chromaTitle} intro={st.chromaIntro} />
    <div class="mt-10 grid grid-cols-7 gap-2 md:gap-4">
      {chromaKeys.map((ck, i) => (
        <div class="rounded-xl p-3 text-center text-ink" style={`background:${ck.color}`}><p class="font-display text-xl font-700">{ck.degree}</p><p class="text-xs font-700">{emotions[i]}</p></div>
      ))}
    </div>
    <p class="mt-6 text-center font-display text-lg font-600 text-gold">{st.chromaPunch}</p>
    <div class="mt-10 grid gap-6 md:grid-cols-2">
      <figure class="overflow-hidden rounded-card border border-cream/10"><img src="/images/invisible-visible.webp" width="1500" height="1213" alt={st.chromaTitle} class="w-full object-cover" loading="lazy" /></figure>
      <figure class="overflow-hidden rounded-card border border-cream/10"><img src="/images/constel-polygone.webp" width="1400" height="992" alt={st.constelTitle} class="w-full object-cover" loading="lazy" /></figure>
    </div>
  </Section>

  <Section>
    <SectionHeading eyebrow={st.constelEyebrow} title={st.constelTitle} intro={st.constelIntro} />
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {st.constellations.map((co, i) => (
        <figure class="overflow-hidden rounded-card border border-ink/10 bg-cream-deep/40">
          <img src={constelImgs[i].img} width={constelImgs[i].w} height={constelImgs[i].h} alt={co.t} class="aspect-square w-full object-cover" loading="lazy" />
          <figcaption class="p-5"><p class="font-display text-lg font-700">{co.t}</p><p class="mt-1 text-sm text-ink-soft/85">{co.d}</p></figcaption>
        </figure>
      ))}
    </div>
  </Section>

  <Section tone="cream-deep">
    <SectionHeading eyebrow={st.degEyebrow} title={st.degTitle} intro={st.degIntro} />
    <div class="mx-auto mt-10 flex max-w-3xl flex-wrap justify-center gap-3">
      {chromaKeys.map((ck, i) => (
        <span class="inline-flex items-center gap-2 rounded-full border border-ink/10 bg-cream px-4 py-2 font-700"><span class="h-3 w-3 rounded-full" style={`background:${ck.color}`}></span>{ck.degree} · {emotions[i]}</span>
      ))}
    </div>
  </Section>

  <Section>
    <SectionHeading eyebrow={st.modesEyebrow} title={st.modesTitle} intro={st.modesIntro} />
    <div class="mt-10 grid gap-6 md:grid-cols-2">
      {st.modes.map((m, i) => (
        <div class="flex gap-5 rounded-card border border-ink/10 bg-cream-deep/40 p-5"><img src={modeImgs[i].img} width={modeImgs[i].w} height={modeImgs[i].h} alt={m.t} class="h-24 w-24 shrink-0 rounded-xl object-cover" loading="lazy" /><div><h3 class="font-display text-xl font-700">{m.t}</h3><p class="mt-1 text-sm text-ink-soft/85">{m.d}</p></div></div>
      ))}
    </div>
  </Section>

  <Section tone="ink">
    <div class="grid gap-6 md:grid-cols-2">
      <div class="rounded-card border border-cream/10 bg-cream/5 p-7"><h3 class="font-display text-2xl font-700 text-cream">{st.versionAcoTitle}</h3><p class="mt-3 text-cream/75">{st.versionAcoText}</p><div class="mt-5"><Button href={L('/le-neotone')} variant="light">{st.versionAcoCta}</Button></div></div>
      <div class="rounded-card border border-cream/10 bg-cream/5 p-7"><h3 class="font-display text-2xl font-700 text-cream">{st.versionNeoTitle}</h3><p class="mt-3 text-cream/75">{st.versionNeoText}</p><div class="mt-5"><Button href={L('/le-neotone') + '#technologie'} variant="ghost" class="!border-cream/30 !text-cream hover:!bg-cream/10">{st.versionNeoCta}</Button></div></div>
    </div>
  </Section>

  <Section>
    <div class="mx-auto max-w-3xl">
      <SectionHeading align="left" eyebrow={st.storyEyebrow} title={st.storyTitle} />
      <div class="mt-6 space-y-4 text-lg text-ink-soft/90"><p>{st.storyP1}</p><p>{st.storyP2}</p><p set:html={st.storyP3}></p></div>
    </div>
  </Section>

  <Section tone="ink" id="videos">
    <SectionHeading tone="light" eyebrow={st.videosEyebrow} title={st.videosTitle} intro={st.videosIntro} />
    <div class="mt-10">
      <VideoGrid items={st.videos.map((v, i) => ({ ...v, src: studioVideos[i].src, poster: studioVideos[i].poster }))} />
    </div>
  </Section>

  <Section tone="cream-deep" id="liste-attente">
    <div class="mx-auto max-w-2xl rounded-card border border-ink/10 bg-cream p-8 text-center md:p-12">
      <Icon name="lucide:sparkles" class="mx-auto h-9 w-9 text-copper" />
      <h2 class="mt-4 font-display text-2xl font-700 md:text-3xl">{st.waitTitle}</h2>
      <p class="mt-3 text-ink-soft/85">{st.waitText}</p>
      <div class="mt-7"><Button href={site.appUrl + '?signup=1'} external variant="primary">{st.waitButton}</Button></div>
    </div>
  </Section>
</Layout>
