---
import Layout from '@/layouts/Layout.astro'
import Section from '@/components/Section.astro'
import SectionHeading from '@/components/SectionHeading.astro'
import Button from '@/components/Button.astro'
import Carousel from '@/components/Carousel.astro'
import Lightbox from '@/components/Lightbox.astro'
import { Icon } from 'astro-icon/components'
import { categoryIds, products } from '@/data/shop'
import { site } from '@/data/site'
import { getDict } from '@/i18n/dict'
import { localizePath } from '@/i18n/utils'
import { itemListLdJson, breadcrumbLdJson } from '@/lib/ldJson'
import type { Lang } from '@/i18n/config'

interface Props { lang: Lang }
const { lang } = Astro.props
const t = getDict(lang)
const s = t.shop
const L = (p: string) => localizePath(p, lang)
const snipcartKey = import.meta.env.PUBLIC_SNIPCART_KEY || ''
const eur = (n: number) => n.toLocaleString(lang === 'en' ? 'en-GB' : 'fr-FR') + ' €'
const productCopy = s.products as Record<string, { name: string; description: string }>
const categoryCopy = s.categories as Record<string, { label: string; blurb: string }>
const linkTags = s.linkTags as Record<string, string>
const linkCtas = s.linkCtas as Record<string, string>
const priceNotes = s.priceNotes as Record<string, string>
const pName = (id: string) => productCopy[id]
const catInfo = (id: string) => categoryCopy[id]

const ld = [
  itemListLdJson(products.filter((p) => p.active).map((p) => ({ name: pName(p.id).name, url: p.url, image: p.image }))),
  breadcrumbLdJson([{ name: t.common.nav.home, url: L('/') }, { name: s.eyebrow, url: L('/boutique') }]),
]
---

<Layout title={s.title} description={s.description} ldJSON={ld}>
  <Section tone="ink" class="!py-16">
    <SectionHeading level={1} tone="light" eyebrow={s.eyebrow} title={s.title2} intro={s.intro} />
    <p class="mx-auto mt-6 max-w-2xl text-center text-cream/75">{s.ambassadorText}</p>
  </Section>


  {categoryIds.map((catId) => {
    const cat = catInfo(catId)
    const items = products.filter((p) => p.category === catId && (p.active || p.mode === 'soon'))
    return (
      <Section id={catId} tone={catId === 'creations' ? 'cream-deep' : 'cream'} class="!py-10 lg:!py-12">
        {catId === 'creations' && (
          <span class="mb-4 inline-flex items-center gap-2 rounded-full bg-copper/15 px-4 py-1.5 text-xs font-700 uppercase tracking-widest text-copper"><Icon name="lucide:sparkles" class="h-4 w-4" /> {s.creationsBadge}</span>
        )}
        <SectionHeading align="left" eyebrow={cat.label} title={cat.label} intro={cat.blurb} />
        <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {items.map((p) => {
            const info = pName(p.id)
            return (
              <div id={p.id} class="flex flex-col overflow-hidden rounded-card border border-ink/10 bg-cream-deep/40">
                {p.images && p.images.length > 1 ? (
                  <div class="p-3"><Carousel id={`shop-${p.id}`} slides={p.images.map((src) => ({ src }))} alt={info.name} /></div>
                ) : (
                  <div class="aspect-square bg-ink/5 p-6"><img src={p.image} width={p.imgW} height={p.imgH} alt={info.name} class="h-full w-full object-contain" loading="lazy" /></div>
                )}
                <div class="flex flex-1 flex-col p-6">
                  <h3 class="font-display text-xl font-700">{info.name}</h3>
                  <p class="mt-2 text-sm text-ink-soft/85" set:html={info.description} />
                  {p.videoUrls && p.videoUrls.map((v, vi) => (
                    <a href={v} target="_blank" rel="noopener" class="mt-3 inline-flex items-center gap-2 self-start text-sm font-700 text-rust hover:underline">
                      <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current" aria-hidden="true"><path d="M8 5v14l11-7z"></path></svg>{s.watchDemo}{p.videoUrls!.length > 1 ? ` ${vi + 1}` : ''}
                    </a>
                  ))}
                  <div class="flex-1"></div>
                  <div class="mt-4 flex flex-wrap items-center justify-between gap-2">
                    {p.mode === 'soon' && <span class="text-sm font-600 text-ink-soft/60">{s.soon}</span>}
                    {(p.mode === 'cart' || p.mode === 'quote') && <span class="font-display text-lg font-700">{p.mode === 'quote' ? s.from : ''}{eur(p.price)}</span>}
                    {p.mode === 'link' && p.priceLabel && <span class="font-display text-lg font-700">{p.priceLabel}</span>}
                    {p.mode === 'link' && p.tagKey && <span class="inline-flex items-center gap-1.5 rounded-full bg-copper/15 px-3 py-1 text-xs font-700 text-copper">{linkTags[p.tagKey]}</span>}
                  </div>
                  {p.priceNoteKey && (
                    <div class="mt-3 rounded-lg border border-copper/30 bg-copper/5 p-3 text-xs leading-relaxed text-ink-soft/90" set:html={priceNotes[p.priceNoteKey]} />
                  )}
                  <div class="mt-4">
                    {p.mode === 'cart' && snipcartKey && (
                      <button class="snipcart-add-item w-full rounded-full bg-rust px-5 py-3 font-700 text-cream transition-colors hover:bg-copper" data-item-id={p.id} data-item-name={info.name} data-item-price={p.price} data-item-url="/boutique" data-item-description={info.description} data-item-image={p.image}>{s.addCart}</button>
                    )}
                    {p.mode === 'cart' && !snipcartKey && (
                      <a href={`mailto:${site.email}?subject=${encodeURIComponent(info.name)}`} class="block w-full rounded-full bg-rust px-5 py-3 text-center font-700 text-cream hover:bg-copper">{s.orderEmail}</a>
                    )}
                    {p.mode === 'quote' && <a href={L('/le-neotone') + '#calculateur'} class="block w-full rounded-full bg-rust px-5 py-3 text-center font-700 text-cream hover:bg-copper">{s.calcOrder}</a>}
                    {p.mode === 'link' && <a href={p.url.startsWith('/') ? L(p.url) : p.url} target={p.url.startsWith('/') || p.url.startsWith('mailto:') ? undefined : '_blank'} rel="noopener" class="block w-full rounded-full bg-rust px-5 py-3 text-center font-700 text-cream hover:bg-copper">{linkCtas[p.linkLabel || 'buy']}</a>}
                    {p.mode === 'soon' && <span class="block w-full rounded-full border border-ink/15 px-5 py-3 text-center font-600 text-ink-soft/50">{s.soonLong}</span>}
                  </div>
                </div>
              </div>
            )
          })}
        </div>
      </Section>
    )
  })}

  <Section tone="cream-deep">
    <div class="rounded-card border border-ink/10 bg-cream p-8 text-center">
      <Icon name="lucide:messages-square" class="mx-auto h-9 w-9 text-copper" />
      <h2 class="mt-4 font-display text-2xl font-700">{s.adviceTitle}</h2>
      <p class="mx-auto mt-3 max-w-xl text-ink-soft/85">{s.adviceText}</p>
      <div class="mt-6"><Button href={L('/contact')} variant="primary">{s.adviceCta}</Button></div>
    </div>
  </Section>

  <Lightbox />
</Layout>
