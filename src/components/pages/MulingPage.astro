---
import Layout from '@/layouts/Layout.astro'
import Section from '@/components/Section.astro'
import SectionHeading from '@/components/SectionHeading.astro'
import Button from '@/components/Button.astro'
import Carousel from '@/components/Carousel.astro'
import Lightbox from '@/components/Lightbox.astro'
import YouTube from '@/components/YouTube.astro'
import { Icon } from 'astro-icon/components'
import { mulingPhotos, mulingVideoId, mulingPriceUsd, mulingPriceEurApprox, mulingMakerUrl } from '@/data/muling'
import { site } from '@/data/site'
import { getDict } from '@/i18n/dict'
import { localizePath } from '@/i18n/utils'
import { breadcrumbLdJson } from '@/lib/ldJson'
import type { Lang } from '@/i18n/config'

interface Props { lang: Lang }
const { lang } = Astro.props
const t = getDict(lang)
const m = t.muling
const L = (p: string) => localizePath(p, lang)

const contactHref = `mailto:${site.email}?subject=${encodeURIComponent(
  lang === 'en' ? 'Muling microphone — I’m interested' : 'Micro Muling — je suis intéressé(e)',
)}&body=${encodeURIComponent(
  (lang === 'en'
    ? ['Hi David,', '', 'I’m interested in the Muling microphone for acoustic handpan.', '', 'My details:', '• Full name: ', '• Country: ', '• My handpan (maker / scale): ', '', 'Thanks!']
    : ['Bonjour David,', '', 'Je suis intéressé·e par le micro Muling pour handpan acoustique.', '', 'Mes coordonnées :', '• Nom et prénom : ', '• Pays : ', '• Mon handpan (fabricant / gamme) : ', '', 'Merci !']
  ).join('\n'),
)}`

const ld = [
  breadcrumbLdJson([
    { name: t.common.nav.home, url: L('/') },
    { name: t.common.nav.shop, url: L('/boutique') },
    { name: m.heroTitle, url: L('/micro-muling') },
  ]),
]
---

<Layout title={m.title} description={m.description} ldJSON={ld}>
  <section class="relative overflow-hidden bg-ink text-cream">
    <div class="chroma-bar absolute inset-x-0 top-0 h-1"></div>
    <div class="mx-auto max-w-7xl px-4 py-16 lg:px-8 lg:py-24">
      <a href={L('/boutique') + '#micros'} class="text-sm font-600 text-cream/70 hover:text-gold">{m.back}</a>
      <div class="mt-6 grid items-center gap-10 lg:grid-cols-2">
        <div>
          <p class="text-xs font-700 uppercase tracking-[0.2em] text-gold">{m.eyebrow}</p>
          <h1 class="mt-4 font-display text-4xl font-700 leading-tight md:text-5xl">{m.heroTitle}</h1>
          <p class="mt-5 text-lg text-cream/85">{m.heroLead}</p>
          <div class="mt-8 flex flex-wrap gap-3">
            <Button href={contactHref} variant="primary">{m.ctaInterested}</Button>
            <Button href="#video" variant="light">{m.ctaVideo}</Button>
          </div>
        </div>
        <div class="overflow-hidden rounded-card shadow-md">
          <img src={mulingPhotos[0]} width="1200" height="1200" alt={m.heroTitle} class="w-full object-cover" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <Section id="video">
    <SectionHeading eyebrow={m.eyebrow} title={m.videoTitle} intro={m.videoIntro} />
    <div class="mx-auto mt-10 max-w-3xl">
      <YouTube id={mulingVideoId} title={m.videoTitle} />
    </div>
  </Section>

  <Section tone="cream-deep">
    <SectionHeading title={m.whyTitle} intro={m.whyText} />
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {m.whyPoints.map((p) => (
        <div class="rounded-card border border-ink/10 bg-cream p-6">
          <Icon name="lucide:mic" class="h-8 w-8 text-copper" />
          <h3 class="mt-3 font-display text-lg font-700">{p.t}</h3>
          <p class="mt-2 text-sm text-ink-soft/85">{p.d}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section>
    <SectionHeading title={m.photosTitle} intro={m.photosIntro} />
    <div class="mx-auto mt-10 max-w-3xl">
      <Carousel id="muling-photos" slides={mulingPhotos.map((src) => ({ src }))} alt={m.heroTitle} />
    </div>
  </Section>

  <Section tone="cream-deep" id="commande">
    <SectionHeading title={m.priceTitle} />
    <div class="mx-auto mt-10 max-w-3xl space-y-6">
      <div class="flex flex-wrap items-baseline justify-between gap-3 rounded-card border border-copper/30 bg-copper/5 p-6">
        <span class="font-600 text-ink-soft">{m.priceLabel}</span>
        <span class="font-display text-2xl font-700 text-ink">{mulingPriceUsd} USD <span class="text-lg font-600 text-ink-soft/70">(≈ {mulingPriceEurApprox} €)</span></span>
      </div>
      <p class="text-sm text-ink-soft/75">{m.priceNote}</p>

      <div class="rounded-card border border-ink/10 bg-cream p-6">
        <h3 class="font-display text-xl font-700">{m.orderTitle}</h3>
        <p class="mt-3 text-ink-soft/85">{m.orderText}</p>
        <p class="mt-4 rounded-lg border border-rust/25 bg-rust/5 p-4 text-sm font-600 text-rust">{m.orderWip}</p>
        <div class="mt-6"><Button href={contactHref} variant="primary">{m.ctaContact}</Button></div>
      </div>

      <div class="rounded-card border border-ink/10 bg-cream p-6">
        <h3 class="font-display text-xl font-700">{m.makerTitle}</h3>
        <p class="mt-3 text-ink-soft/85">{m.makerText}</p>
        <a href={mulingMakerUrl} target="_blank" rel="noopener" class="mt-4 inline-block font-700 text-rust underline">{m.makerCta}</a>
      </div>
    </div>
  </Section>

  <Section tone="ink">
    <div class="mx-auto max-w-3xl rounded-card border border-cream/10 bg-cream/5 p-8 text-center md:p-10">
      <h2 class="font-display text-2xl font-700 text-cream md:text-3xl">{m.relatedTitle}</h2>
      <p class="mx-auto mt-4 max-w-2xl text-cream/75">{m.relatedText}</p>
      <div class="mt-7"><Button href={L('/le-neotone')} variant="light">{m.relatedCta}</Button></div>
    </div>
  </Section>

  <Lightbox />
</Layout>
