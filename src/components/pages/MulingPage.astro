---
import Layout from '@/layouts/Layout.astro'
import Section from '@/components/Section.astro'
import SectionHeading from '@/components/SectionHeading.astro'
import Button from '@/components/Button.astro'
import Carousel from '@/components/Carousel.astro'
import Lightbox from '@/components/Lightbox.astro'
import YouTube from '@/components/YouTube.astro'
import { Icon } from 'astro-icon/components'
import {
  mulingHero, mulingPhotos, mulingPreampPhotos, mulingBoxPhotos, mulingPowerPhotos,
  mulingDiagram, mulingManualPhotos, mulingVideoId, mulingPriceUsd, mulingPriceEurApprox,
} from '@/data/muling'
import { site } from '@/data/site'
import { getDict } from '@/i18n/dict'
import { localizePath } from '@/i18n/utils'
import { breadcrumbLdJson } from '@/lib/ldJson'
import type { Lang } from '@/i18n/config'

interface Props { lang: Lang }
const { lang } = Astro.props
const t = getDict(lang)
const m = t.muling
const L = (p: string) => localizePath(p, lang)

const contactHref = `mailto:${site.email}?subject=${encodeURIComponent(
  lang === 'en' ? 'Muling microphone — I’m interested' : 'Micro Muling — je suis intéressé(e)',
)}&body=${encodeURIComponent(
  (lang === 'en'
    ? ['Hi David,', '', 'I’m interested in the Muling microphone for acoustic handpan.', '', 'My details:', '• Full name: ', '• Country: ', '• My handpan (maker / scale): ', '', 'Thanks!']
    : ['Bonjour David,', '', 'Je suis intéressé·e par le micro Muling pour handpan acoustique.', '', 'Mes coordonnées :', '• Nom et prénom : ', '• Pays : ', '• Mon handpan (fabricant / gamme) : ', '', 'Merci !']
  ).join('\n'),
)}`

const ld = [
  breadcrumbLdJson([
    { name: t.common.nav.home, url: L('/') },
    { name: t.common.nav.shop, url: L('/boutique') },
    { name: m.heroTitle, url: L('/micro-muling') },
  ]),
]
---

<Layout title={m.title} description={m.description} ldJSON={ld}>
  <section class="relative overflow-hidden bg-ink text-cream">
    <div class="chroma-bar absolute inset-x-0 top-0 h-1"></div>
    <div class="mx-auto max-w-7xl px-4 py-16 lg:px-8 lg:py-24">
      <a href={L('/boutique') + '#micros'} class="text-sm font-600 text-cream/70 hover:text-gold">{m.back}</a>
      <div class="mt-6 grid items-center gap-10 lg:grid-cols-2">
        <div>
          <p class="text-xs font-700 uppercase tracking-[0.2em] text-gold">{m.eyebrow}</p>
          <h1 class="mt-4 font-display text-4xl font-700 leading-tight md:text-5xl">{m.heroTitle}</h1>
          <p class="mt-5 text-lg text-cream/85">{m.heroLead}</p>
          <div class="mt-8 flex flex-wrap gap-3">
            <Button href={contactHref} variant="primary">{m.ctaInterested}</Button>
            <Button href="#video" variant="light">{m.ctaVideo}</Button>
          </div>
        </div>
        <div class="overflow-hidden rounded-card shadow-md">
          <img src={mulingHero} width="1500" height="1500" alt={m.heroTitle} class="aspect-square w-full bg-cream object-contain" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <Section id="video">
    <SectionHeading eyebrow={m.eyebrow} title={m.videoTitle} intro={m.videoIntro} />
    <div class="mx-auto mt-10 max-w-3xl">
      <YouTube id={mulingVideoId} title={m.videoTitle} />
    </div>
  </Section>

  <Section tone="cream-deep">
    <SectionHeading title={m.whyTitle} intro={m.whyText} />
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {m.whyPoints.map((p) => (
        <div class="rounded-card border border-ink/10 bg-cream p-6">
          <Icon name="lucide:mic" class="h-8 w-8 text-copper" />
          <h3 class="mt-3 font-display text-lg font-700">{p.t}</h3>
          <p class="mt-2 text-sm text-ink-soft/85">{p.d}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section id="contenu">
    <SectionHeading title={m.boxTitle} intro={m.boxIntro} />
    <div class="mt-10 grid items-center gap-8 lg:grid-cols-2">
      <Carousel id="muling-box" slides={mulingBoxPhotos.map((src) => ({ src }))} alt={m.boxTitle} />
      <div>
        <ul class="space-y-2.5">
          {m.boxItems.map((it) => (
            <li class="flex gap-3 text-ink-soft/90"><Icon name="lucide:check" class="mt-1 h-5 w-5 shrink-0 text-copper" />{it}</li>
          ))}
        </ul>
        <p class="mt-6 rounded-lg border border-copper/25 bg-copper/5 p-4 text-sm text-ink-soft/90">{m.boxNote}</p>
      </div>
    </div>
  </Section>

  <Section tone="cream-deep" id="specs">
    <SectionHeading title={m.specsTitle} intro={m.specsIntro} />
    <div class="mx-auto mt-10 max-w-4xl">
      <div class="grid gap-5 sm:grid-cols-2">
        {m.specs.map((sp) => (
          <div class="rounded-card border border-ink/10 bg-cream-deep/40 p-5">
            <h3 class="flex items-center gap-2 font-display text-lg font-700"><Icon name="lucide:check" class="h-5 w-5 shrink-0 text-copper" />{sp.t}</h3>
            <p class="mt-2 text-sm text-ink-soft/85">{sp.d}</p>
          </div>
        ))}
      </div>
      <p class="mt-6 rounded-lg border border-copper/25 bg-copper/5 p-4 text-sm text-ink-soft/90">{m.specsCaution}</p>
      <p class="mt-3 text-xs text-ink-soft/60">{m.specsSource}</p>
    </div>
  </Section>

  <Section id="preampli">
    <SectionHeading title={m.preampTitle} intro={m.preampIntro} />
    <div class="mt-10 grid items-start gap-8 lg:grid-cols-2">
      <Carousel id="muling-preamp" slides={mulingPreampPhotos.map((src) => ({ src }))} alt={m.preampTitle} />
      <div class="space-y-4">
        {m.preampFeatures.map((f) => (
          <div class="rounded-card border border-ink/10 bg-cream-deep/40 p-5">
            <h3 class="font-display text-lg font-700">{f.t}</h3>
            <p class="mt-1.5 text-sm text-ink-soft/85">{f.d}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="mx-auto mt-12 max-w-4xl">
      <h3 class="text-center font-display text-xl font-700">{m.preampDiagramTitle}</h3>
      <img src={mulingDiagram[lang]} width="1500" height="960" alt={m.preampDiagramAlt} class="mt-5 w-full rounded-card border border-ink/10 bg-cream shadow-sm" loading="lazy" />
    </div>

    <div class="mx-auto mt-10 max-w-3xl rounded-card border border-rust/25 bg-rust/5 p-6">
      <h3 class="flex items-center gap-2 font-display text-lg font-700 text-rust"><Icon name="lucide:alert-triangle" class="h-5 w-5" />{m.preampWarnTitle}</h3>
      <ul class="mt-3 space-y-2">
        {m.preampWarns.map((w) => <li class="text-sm text-ink-soft/90">• {w}</li>)}
      </ul>
    </div>
  </Section>

  <Section tone="cream-deep" id="alimentation">
    <SectionHeading title={m.powerTitle} intro={m.powerIntro} />
    <div class="mt-10 grid gap-6 lg:grid-cols-2">
      <div class="overflow-hidden rounded-card border border-ink/10 bg-cream">
        <img src="/images/muling-preampli-ouvert-pile.webp" width="1500" height="1561" alt={m.powerBattery.t} class="aspect-[4/3] w-full object-cover" loading="lazy" />
        <div class="p-6">
          <h3 class="font-display text-lg font-700">{m.powerBattery.t}</h3>
          <p class="mt-2 text-sm text-ink-soft/85">{m.powerBattery.d}</p>
        </div>
      </div>
      <div class="overflow-hidden rounded-card border border-ink/10 bg-cream">
        <img src={mulingPowerPhotos[0]} width="1500" height="2666" alt={m.powerMains.t} class="aspect-[4/3] w-full object-cover" loading="lazy" />
        <div class="p-6">
          <h3 class="font-display text-lg font-700">{m.powerMains.t}</h3>
          <p class="mt-2 text-sm text-ink-soft/85">{m.powerMains.d}</p>
        </div>
      </div>
    </div>
    <p class="mx-auto mt-8 max-w-3xl rounded-card border border-rust/30 bg-rust/10 p-5 text-center font-600 text-rust">{m.powerWarning}</p>
  </Section>

  <Section>
    <SectionHeading title={m.photosTitle} intro={m.photosIntro} />
    <div class="mx-auto mt-10 max-w-3xl">
      <Carousel id="muling-photos" slides={mulingPhotos.map((src) => ({ src }))} alt={m.heroTitle} />
    </div>
  </Section>

  <Section tone="cream-deep" id="manuel">
    <SectionHeading title={m.manualTitle} intro={m.manualIntro} />
    <div class="mx-auto mt-10 grid max-w-4xl gap-6 sm:grid-cols-2">
      {mulingManualPhotos.map((src, i) => (
        <img src={src} width="1500" height="2666" alt={`${m.manualTitle} — ${i + 1}`} class="w-full rounded-card border border-ink/10 bg-cream shadow-sm" loading="lazy" />
      ))}
    </div>
  </Section>

  <Section id="commande">
    <SectionHeading title={m.priceTitle} />
    <div class="mx-auto mt-10 max-w-3xl space-y-6">
      <div class="flex flex-wrap items-baseline justify-between gap-3 rounded-card border border-copper/30 bg-copper/5 p-6">
        <span class="font-600 text-ink-soft">{m.priceLabel}</span>
        <span class="font-display text-2xl font-700 text-ink">{mulingPriceUsd} USD <span class="text-lg font-600 text-ink-soft/70">(≈ {mulingPriceEurApprox} €)</span></span>
      </div>
      <p class="text-sm text-ink-soft/75">{m.priceNote}</p>

      <div class="rounded-card border border-ink/10 bg-cream p-6">
        <h3 class="font-display text-xl font-700">{m.orderTitle}</h3>
        <p class="mt-3 text-ink-soft/85">{m.orderText}</p>
        <p class="mt-4 rounded-lg border border-rust/25 bg-rust/5 p-4 text-sm font-600 text-rust">{m.orderWip}</p>
        <div class="mt-6"><Button href={contactHref} variant="primary">{m.ctaContact}</Button></div>
      </div>

    </div>
  </Section>

  <Section tone="ink">
    <div class="mx-auto max-w-3xl rounded-card border border-cream/10 bg-cream/5 p-8 text-center md:p-10">
      <h2 class="font-display text-2xl font-700 text-cream md:text-3xl">{m.relatedTitle}</h2>
      <p class="mx-auto mt-4 max-w-2xl text-cream/75">{m.relatedText}</p>
      <div class="mt-7"><Button href={L('/le-neotone')} variant="light">{m.relatedCta}</Button></div>
    </div>
  </Section>

  <Lightbox />
</Layout>
