---
import Layout from '@/layouts/Layout.astro'
import Section from '@/components/Section.astro'
import SectionHeading from '@/components/SectionHeading.astro'
import { Icon } from 'astro-icon/components'
import { site } from '@/data/site'
import { getDict } from '@/i18n/dict'
import type { Lang } from '@/i18n/config'

interface Props { lang: Lang }
const { lang } = Astro.props
const t = getDict(lang)
const ct = t.contact
const coords = [
  { icon: 'lucide:mail', t: ct.coords.email, v: site.email, href: `mailto:${site.email}` },
  { icon: 'lucide:phone', t: ct.coords.phone, v: site.phone, href: `tel:${site.phoneHref}` },
  { icon: 'lucide:map-pin', t: ct.coords.showroom, v: site.address, href: site.mapsUrl },
]
---

<Layout title={ct.title} description={ct.description}>
  <Section tone="ink" class="!py-16">
    <SectionHeading level={1} tone="light" eyebrow={ct.eyebrow} title={ct.title2} intro={ct.intro} />
  </Section>

  <Section>
    <div class="grid gap-10 lg:grid-cols-2">
      <div>
        <div class="space-y-4">
          {coords.map((c) => (
            <a href={c.href} class="flex items-center gap-4 rounded-card border border-ink/10 bg-cream-deep/40 p-5 transition-colors hover:bg-cream-deep"><Icon name={c.icon} class="h-7 w-7 text-copper" /><div><p class="text-sm font-700 uppercase tracking-wide text-ink-soft/60">{c.t}</p><p class="font-display text-lg font-700">{c.v}</p></div></a>
          ))}
        </div>
        <div class="mt-6 flex gap-3">
          <a href={site.social.instagram} class="rounded-full border border-ink/15 px-4 py-2 text-sm font-600 hover:bg-ink/5" target="_blank" rel="noopener">Instagram</a>
          <a href={site.social.facebook} class="rounded-full border border-ink/15 px-4 py-2 text-sm font-600 hover:bg-ink/5" target="_blank" rel="noopener">Facebook</a>
          <a href={site.social.youtube} class="rounded-full border border-ink/15 px-4 py-2 text-sm font-600 hover:bg-ink/5" target="_blank" rel="noopener">YouTube</a>
        </div>
      </div>

      <form id="contact-form" class="rounded-card border border-ink/10 bg-cream-deep/40 p-6 md:p-8" name="contact" data-to={site.email}>
        <div class="grid gap-4">
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block"><span class="text-sm font-600">{ct.form.name}</span><input type="text" name="name" required class="mt-1 w-full rounded-xl border border-ink/20 bg-cream px-4 py-3 focus:border-copper focus:outline-none" /></label>
            <label class="block"><span class="text-sm font-600">{ct.form.email}</span><input type="email" name="email" required class="mt-1 w-full rounded-xl border border-ink/20 bg-cream px-4 py-3 focus:border-copper focus:outline-none" /></label>
          </div>
          <label class="block"><span class="text-sm font-600">{ct.form.subject}</span>
            <select name="subject" class="mt-1 w-full rounded-xl border border-ink/20 bg-cream px-4 py-3 focus:border-copper focus:outline-none">
              {ct.subjects.map((su) => <option>{su}</option>)}
            </select>
          </label>
          <label class="block"><span class="text-sm font-600">{ct.form.message}</span><textarea name="message" rows="5" required class="mt-1 w-full rounded-xl border border-ink/20 bg-cream px-4 py-3 focus:border-copper focus:outline-none"></textarea></label>
          <button type="submit" class="rounded-full bg-rust px-6 py-3 font-700 text-cream transition-colors hover:bg-copper">{ct.form.submit}</button>
          <p class="text-xs text-ink-soft/60">{ct.form.note} {site.email}.</p>
        </div>
      </form>
    </div>
  </Section>

  <script>
    // Le site est statique (Vercel) : pas de traitement POST côté serveur.
    // À l'envoi, on ouvre le logiciel de mail avec un message déjà rédigé.
    const form = document.getElementById('contact-form') as HTMLFormElement | null
    form?.addEventListener('submit', (e) => {
      e.preventDefault()
      const data = new FormData(form)
      const get = (k: string) => String(data.get(k) || '').trim()
      const to = form.dataset.to || ''
      const subject = `${get('subject')} — ${get('name')}`
      const body = [get('message'), '', '—', get('name'), get('email')].join('\n')
      window.location.href = `mailto:${to}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`
    })
  </script>
</Layout>
