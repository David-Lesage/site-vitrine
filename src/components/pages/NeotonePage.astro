---
import Layout from '@/layouts/Layout.astro'
import Section from '@/components/Section.astro'
import SectionHeading from '@/components/SectionHeading.astro'
import Button from '@/components/Button.astro'
import Calculator from '@/components/Calculator.astro'
import Carousel from '@/components/Carousel.astro'
import Lightbox from '@/components/Lightbox.astro'
import WoodModal from '@/components/WoodModal.astro'
import { Icon } from 'astro-icon/components'
import { models, woods, woodNames, modelCarousels, specIcons, includedIcons, extrasIcons } from '@/data/neotone'
import { site } from '@/data/site'
import { getDict } from '@/i18n/dict'
import { localizePath } from '@/i18n/utils'
import { faqLdJson, productLdJson, breadcrumbLdJson } from '@/lib/ldJson'
import type { Lang } from '@/i18n/config'

interface Props { lang: Lang }
const { lang } = Astro.props
const t = getDict(lang)
const n = t.neotone
const d = t.data
const L = (p: string) => localizePath(p, lang)
const modelLabels: Record<string, string> = { one: 'Neotone¹', mutant: 'Neotone¹ Mutant' }

// Petits logos handpan pour le comparatif : acoustique (métal monochrome) vs électronique (couleurs ChromaKeys)
const acoGlyph = `<svg viewBox="0 0 28 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-6 w-7 shrink-0 text-ink-soft/60" aria-hidden="true"><ellipse cx="14" cy="13" rx="12" ry="9" fill="currentColor" fill-opacity="0.1" stroke="currentColor" stroke-width="1.4"/><circle cx="14" cy="13" r="2.6" fill="currentColor"/><circle cx="14" cy="6.5" r="1.5" fill="currentColor" fill-opacity="0.6"/><circle cx="7.5" cy="10.5" r="1.5" fill="currentColor" fill-opacity="0.6"/><circle cx="20.5" cy="10.5" r="1.5" fill="currentColor" fill-opacity="0.6"/><circle cx="9.5" cy="17.5" r="1.5" fill="currentColor" fill-opacity="0.6"/><circle cx="18.5" cy="17.5" r="1.5" fill="currentColor" fill-opacity="0.6"/></svg>`
const neoGlyph = `<svg viewBox="0 0 28 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-6 w-7 shrink-0" aria-hidden="true"><ellipse cx="14" cy="13" rx="12" ry="9" fill="#1f2a44" stroke="#c8792e" stroke-width="1.4"/><circle cx="14" cy="13" r="2.6" fill="#2f6bd8"/><circle cx="14" cy="6.5" r="1.5" fill="#e0402b"/><circle cx="7.5" cy="10.5" r="1.5" fill="#f1c62f"/><circle cx="20.5" cy="10.5" r="1.5" fill="#4caf6d"/><circle cx="9.5" cy="17.5" r="1.5" fill="#8a49b8"/><circle cx="18.5" cy="17.5" r="1.5" fill="#ef8a2a"/></svg>`

const ld = [
  breadcrumbLdJson([{ name: t.common.nav.home, url: L('/') }, { name: n.heroEyebrow, url: L('/le-neotone') }]),
  faqLdJson(d.faq),
  productLdJson({ name: 'Neotone¹', description: 'Handpan numérique professionnel 10 notes', price: 1990, image: '/images/neotone1-1.jpg' }),
  productLdJson({ name: 'Neotone¹ Mutant', description: 'Handpan numérique professionnel 19 notes avec écran LCD', price: 3150, image: '/images/mutant-0.jpg' }),
]
---

<Layout title={n.title} description={n.description} ldJSON={ld}>
  <Section tone="ink" class="!py-20">
    <div class="grid items-center gap-10 lg:grid-cols-2">
      <div>
        <p class="text-xs font-700 uppercase tracking-[0.2em] text-gold">{n.heroEyebrow}</p>
        <h1 class="mt-4 font-display text-4xl font-700 leading-tight md:text-5xl">{n.heroTitle}</h1>
        <p class="mt-5 text-lg text-cream/80" set:html={n.heroLead}></p>
        <div class="mt-8 flex flex-wrap gap-3">
          <Button href="#calculateur" variant="primary">{n.ctaCalc}</Button>
          <Button href={L('/showroom')} variant="light">{n.ctaShowroom}</Button>
        </div>
      </div>
      <div class="overflow-hidden rounded-card shadow-md"><img src="/images/neotone-hero-david.webp" width="1800" height="1200" alt="David Lesage avec les handpans Neotone (Neotone¹ et Mutant)" class="w-full object-cover" loading="eager" /></div>
    </div>
  </Section>

  <Section id="modeles">
    <SectionHeading eyebrow={n.modelsEyebrow} title={n.modelsTitle} intro={n.modelsIntro} />
    <div class="mt-12 grid gap-8 md:grid-cols-2">
      {models.map((m) => (
        <div class="flex flex-col overflow-hidden rounded-card border border-ink/10 bg-cream-deep/40">
          <div class="p-4"><Carousel id={m.id} slides={modelCarousels[m.id]} alt={modelLabels[m.id]} /></div>
          <div class="flex flex-1 flex-col p-6 pt-2">
            <div class="flex items-baseline justify-between">
              <h3 class="font-display text-2xl font-700">{modelLabels[m.id]}</h3>
              <span class="rounded-full bg-copper/15 px-3 py-1 text-xs font-700 text-copper">{d.modelNotes[m.id]}</span>
            </div>
            <p class="mt-1 text-ink-soft/80">{d.modelTaglines[m.id]}</p>
            <ul class="mt-4 flex-1 space-y-2 text-sm text-ink-soft/90">
              {d.modelFeatures[m.id].map((f) => <li class="flex gap-2"><Icon name="lucide:check" class="mt-0.5 h-4 w-4 shrink-0 text-copper" /> {f}</li>)}
            </ul>
            <p class="mt-5 font-display text-lg font-700">{n.fromPrice} {m.fromPrice.toLocaleString(lang === 'en' ? 'en-GB' : 'fr-FR')} € HT</p>
          </div>
        </div>
      ))}
    </div>
  </Section>

  <Section tone="cream-deep" id="bois">
    <SectionHeading eyebrow={n.woodsEyebrow} title={n.woodsTitle} intro={n.woodsIntro} />
    <div class="mx-auto mt-12 grid max-w-5xl grid-cols-2 gap-x-6 gap-y-10 sm:grid-cols-3 lg:grid-cols-5">
      {woods.map((w) => (
        <button type="button" class="wood-card" data-wood={w.key} aria-label={`${n.woodCardCta} — ${woodNames[w.key][lang]}`}>
          <span class="wood-card-disc block" data-cta={n.woodCardCta}>
            <img src={w.img} width="570" height="420" alt={woodNames[w.key][lang]} loading="lazy" />
          </span>
          <h4>{woodNames[w.key][lang]}</h4>
          <div class="wood-card-sub">{d.woodEnNames[w.key]}</div>
          <div class="wood-card-supp" set:html={d.woodSupplements[w.key].replace(/(\+\d+\s?€[^,]*)/, '<strong>$1</strong>')}></div>
        </button>
      ))}
    </div>
  </Section>

  <WoodModal lang={lang} />

  <Section id="technologie">
    <div class="grid items-center gap-10 lg:grid-cols-2">
      <div class="aspect-[4/3] overflow-hidden rounded-card"><img src="/images/interieur-1.webp" width="1080" height="1440" alt={n.techTitle} class="h-full w-full object-cover" loading="lazy" /></div>
      <div>
        <SectionHeading align="left" eyebrow={n.techEyebrow} title={n.techTitle} />
        <p class="mt-5 text-lg text-ink-soft/90">{n.techText}</p>
      </div>
    </div>
    <h3 class="mt-16 text-center font-display text-2xl font-700">{n.specsTitle}</h3>
    <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {d.specs.map((s, i) => (
        <div class="rounded-card border border-ink/10 bg-cream-deep/40 p-6">
          <Icon name={specIcons[i]} class="h-7 w-7 text-copper" />
          <h4 class="mt-3 font-display text-lg font-700">{s.title}</h4>
          <ul class="mt-3 space-y-1.5 text-sm text-ink-soft/85">{s.items.map((it) => <li>· {it}</li>)}</ul>
        </div>
      ))}
    </div>
  </Section>

  <Section tone="ink">
    <SectionHeading tone="light" eyebrow={n.stageEyebrow} title={n.stageTitle} intro={n.stageIntro} />
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {n.stage.map((b) => (
        <div class="rounded-card border border-cream/10 bg-cream/5 p-6"><h3 class="font-display text-xl font-700 text-cream">{b.t}</h3><p class="mt-3 text-cream/75">{b.d}</p></div>
      ))}
    </div>
  </Section>

  <Section id="comparatif">
    <SectionHeading eyebrow={n.compEyebrow} title={n.compTitle} intro={n.compIntro} />
    <div class="mx-auto mt-8 flex max-w-4xl flex-wrap items-center justify-center gap-x-8 gap-y-2 text-sm font-600 text-ink-soft">
      <span class="flex items-center gap-2"><span set:html={acoGlyph} />{n.compLegendAco}</span>
      <span class="flex items-center gap-2"><span set:html={neoGlyph} />{n.compLegendNeo}</span>
    </div>
    <div class="mx-auto mt-6 max-w-4xl space-y-4">
      {d.comparatif.map((row) => (
        <div class="grid gap-px overflow-hidden rounded-card border border-ink/10 md:grid-cols-2">
          <div class="flex gap-3 bg-cream-deep/60 p-5"><span class="mt-0.5" set:html={acoGlyph} /><p class="text-sm text-ink-soft/85">{row.aco}</p></div>
          <div class="flex gap-3 bg-copper/10 p-5"><span class="mt-0.5" set:html={neoGlyph} /><p class="text-sm font-600 text-ink">{row.neo}</p></div>
        </div>
      ))}
    </div>
  </Section>

  <Section tone="cream-deep" id="calculateur">
    <SectionHeading eyebrow={n.calcEyebrow} title={n.calcTitle} intro={n.calcIntro} />
    <div class="mt-10"><Calculator lang={lang} /></div>
    <p class="mx-auto mt-6 max-w-3xl text-center text-xs text-ink-soft/70">{n.calcDisclaimer}</p>
  </Section>

  <Section id="procedure">
    <SectionHeading eyebrow={n.procEyebrow} title={n.procTitle} intro={n.procIntro} />
    <p class="mx-auto mt-5 max-w-2xl rounded-card border border-rust/30 bg-rust/10 px-6 py-4 text-center font-display text-lg font-700 text-rust">{n.procHighlight}</p>

    <h3 class="mt-12 flex items-center gap-2 font-display text-xl font-700"><Icon name="lucide:globe" class="h-6 w-6 text-copper" />{n.procOnlineTitle}</h3>
    <ol class="mt-6 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {d.procedure.map((step, i) => (
        <li class="rounded-card border border-ink/10 bg-cream-deep/40 p-6">
          <span class="grid h-9 w-9 place-items-center rounded-full bg-rust font-display text-lg font-700 text-cream">{i + 1}</span>
          <h4 class="mt-4 font-display text-lg font-700">{step.title}</h4>
          <p class="mt-2 text-sm text-ink-soft/85">{step.text}</p>
        </li>
      ))}
    </ol>

    <h3 class="mt-12 flex items-center gap-2 font-display text-xl font-700"><Icon name="lucide:map-pin" class="h-6 w-6 text-copper" />{n.procShowroomTitle}</h3>
    <ol class="mt-6 grid gap-6 md:grid-cols-3">
      {d.procedureShowroom.map((step, i) => (
        <li class="rounded-card border border-copper/25 bg-copper/5 p-6">
          <span class="grid h-9 w-9 place-items-center rounded-full bg-copper font-display text-lg font-700 text-cream">{i + 1}</span>
          <h4 class="mt-4 font-display text-lg font-700">{step.title}</h4>
          <p class="mt-2 text-sm text-ink-soft/85">{step.text}</p>
        </li>
      ))}
    </ol>
  </Section>

  <Section tone="cream-deep">
    <SectionHeading eyebrow={n.inclEyebrow} title={n.inclTitle} />
    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {d.included.map((it, i) => (
        <div class="rounded-card border border-ink/10 bg-cream p-6 text-center"><Icon name={includedIcons[i]} class="mx-auto h-8 w-8 text-copper" /><h3 class="mt-3 font-display text-lg font-700">{it.title}</h3><p class="mt-2 text-sm text-ink-soft/85">{it.text}</p></div>
      ))}
    </div>
  </Section>

  <Section id="extras">
    <SectionHeading eyebrow={n.extrasEyebrow} title={n.extrasTitle} intro={n.extrasIntro} />
    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {d.extras.map((it, i) => (
        <div class="flex flex-col rounded-card border border-ink/10 bg-cream-deep/40 p-6 text-center"><Icon name={extrasIcons[i]} class="mx-auto h-8 w-8 text-copper" /><h3 class="mt-3 font-display text-lg font-700">{it.title}</h3><p class="mt-2 text-sm text-ink-soft/85">{it.text}</p>{i === 0 && <a href={L('/blog/quel-casque-choisir-neotone')} class="mt-3 text-sm font-700 text-rust underline">{n.extrasHeadphonesCta}</a>}{i === 2 && <a href={L('/blog/etre-bien-dans-le-son-neotone')} class="mt-3 text-sm font-700 text-rust underline">{n.extrasSpeakerCta}</a>}</div>
      ))}
    </div>
  </Section>

  <Section tone="ink">
    <div class="mx-auto max-w-3xl rounded-card border border-cream/10 bg-cream/5 p-8 text-center md:p-10">
      <p class="text-xs font-700 uppercase tracking-[0.2em] text-gold">{n.bridgeEyebrow}</p>
      <h2 class="mt-4 font-display text-2xl font-700 text-cream md:text-3xl">{n.bridgeTitle}</h2>
      <p class="mx-auto mt-4 max-w-2xl text-cream/75">{n.bridgeText}</p>
      <div class="mt-7"><Button href={L('/handpan-studio')} variant="light">{n.bridgeCta}</Button></div>
    </div>
  </Section>

  <Section tone="cream-deep">
    <SectionHeading eyebrow={n.trustEyebrow} title={n.trustTitle} />
    <div class="mt-10 grid items-center gap-8 lg:grid-cols-2">
      <div class="space-y-4 text-ink-soft/90">
        <p>{n.trustP1}</p>
        <p>{n.trustP2}</p>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <figure class="overflow-hidden rounded-card shadow-md">
          <img src="/images/prod-neotone-hongrie-equipe.webp" width="821" height="1026" alt="David Lesage avec l’équipe Neotone dans l’atelier en Hongrie" class="aspect-[4/5] w-full object-cover" loading="lazy" />
          <figcaption class="bg-cream px-3 py-2 text-xs text-ink-soft/75">{n.trustCaption2}</figcaption>
        </figure>
        <figure class="overflow-hidden rounded-card shadow-md">
          <img src="/images/prod-neotone-hongrie-debug.webp" width="821" height="1026" alt="David Lesage en session de test et de debug avec l’équipe Neotone" class="aspect-[4/5] w-full object-cover" loading="lazy" />
          <figcaption class="bg-cream px-3 py-2 text-xs text-ink-soft/75">{n.trustCaption1}</figcaption>
        </figure>
      </div>
    </div>
  </Section>

  <Section id="faq">
    <SectionHeading eyebrow={n.faqEyebrow} title={n.faqTitle} />
    <div class="mx-auto mt-10 max-w-3xl space-y-3">
      {d.faq.map((item) => (
        <details class="group rounded-card border border-ink/10 bg-cream-deep/40 p-5">
          <summary class="flex cursor-pointer items-center justify-between gap-4 font-display text-lg font-600 marker:content-none">{item.q}<Icon name="lucide:chevron-down" class="h-5 w-5 shrink-0 text-copper transition-transform group-open:rotate-180" /></summary>
          <p class="mt-3 text-ink-soft/85">{item.a}</p>
        </details>
      ))}
    </div>
    <p class="mt-8 text-center text-ink-soft/85">{n.faqOutro} <a href={`mailto:${site.email}`} class="font-700 text-rust underline">{site.email}</a></p>
  </Section>

  <Lightbox />
</Layout>
