---
import Layout from '@/layouts/Layout.astro'
import Section from '@/components/Section.astro'
import SectionHeading from '@/components/SectionHeading.astro'
import Button from '@/components/Button.astro'
import VideoModal from '@/components/VideoModal.astro'
import { newsletterMailto } from '@/lib/booking'
import { Icon } from 'astro-icon/components'
import YouTube from '@/components/YouTube.astro'
import { site, homeVideos, neotonePlaylist } from '@/data/site'
import { getDict } from '@/i18n/dict'
import { localizePath } from '@/i18n/utils'
import { personLdJson, websiteLdJson, videoLdJson } from '@/lib/ldJson'
import type { Lang } from '@/i18n/config'

interface Props { lang: Lang }
const { lang } = Astro.props
const t = getDict(lang)
const h = t.home
const L = (p: string) => localizePath(p, lang)
// Identifiant de la playlist YouTube, pour l'ouvrir dans la modale (le visiteur reste sur le site)
const playlistId = (neotonePlaylist.match(/list=([\w-]+)/) || [])[1] || ''

// Hero épuré (premium) : le mot-clé en dégradé de marque, les 3 piliers
// en gras doré. Plus de glyphes (notes / smileys / handpan sur les lettres).
const colorWord = lang === 'en' ? 'colours' : 'couleurs'
const geoWord = lang === 'en' ? 'geometry' : 'géométrie'
const emoWord = lang === 'en' ? 'emotions' : 'émotions'
const emphasize = (text: string, words: string[]) =>
  words.reduce((acc, w) => {
    const i = acc.indexOf(w)
    return i === -1 ? acc : `${acc.slice(0, i)}<strong class="font-600 text-gold">${w}</strong>${acc.slice(i + w.length)}`
  }, text)
const heroLeadHtml = emphasize(h.heroLead, [colorWord, geoWord, emoWord])
const universMeta = [
  { img: '/images/neotone-mutant-noyer.webp', w: 600, h: 600, icon: 'lucide:disc-3', href: '/le-neotone', fit: 'contain' },
  { img: '/images/prod-cours-stages.jpg', w: 375, h: 375, icon: 'lucide:graduation-cap', href: '/cours', fit: 'cover-top' },
  { img: '/images/app-acoustique.jpg', w: 1634, h: 902, icon: 'lucide:sparkles', href: '/handpan-studio', fit: 'cover' },
]
---

<Layout title={h.title} description={h.description} ldJSON={[personLdJson(), websiteLdJson(), ...videoLdJson(homeVideos.map((id, i) => ({ id, name: h.proofVideos[i] })))]}>
  <section class="relative overflow-hidden bg-ink text-cream">
    <!-- Photo de David + handpan, pleinement visible à droite -->
    <div class="absolute inset-0">
      <img src="/images/hero-david.webp" width="2400" height="1351" alt="" class="h-full w-full object-cover object-[75%_center]" loading="eager" fetchpriority="high" />
      <!-- Dégradé horizontal : zone opaque à gauche (texte lisible), image révélée à droite -->
      <div class="absolute inset-0 bg-gradient-to-r from-ink via-ink/85 to-transparent md:via-ink/70 md:to-ink/0"></div>
      <!-- Renfort vertical léger pour mobile -->
      <div class="absolute inset-0 bg-gradient-to-t from-ink/85 via-transparent to-transparent md:hidden"></div>
    </div>
    <!-- Filet arc-en-ciel ChromaKeys : « rendre la musique visible » -->
    <div class="chroma-bar absolute inset-x-0 top-0 h-1"></div>
    <div class="relative mx-auto max-w-7xl px-4 py-24 lg:px-8 lg:py-36">
      <div class="max-w-xl text-center md:text-left">
        <p class="inline-flex items-center gap-2 rounded-full border border-cream/20 bg-cream/5 px-4 py-1.5 text-xs font-600 uppercase tracking-[0.2em] text-gold">{h.heroEyebrow}</p>
        <h1 class="mt-6 font-display text-4xl font-700 leading-[1.05] md:text-6xl">{h.heroTitleA} <span class="text-gradient-brand">{h.heroTitleHighlight}</span> {h.heroTitleB}</h1>
        <p class="mt-6 text-lg text-cream/85 md:text-xl" set:html={heroLeadHtml}></p>
        <div class="mt-9 flex flex-wrap justify-center gap-3 md:justify-start">
          <Button href={L('/showroom')} variant="primary">{h.ctaShowroom}</Button>
          <Button href={L('/handpan-studio')} variant="light">{h.ctaMethod}</Button>
        </div>
        <div class="chroma-bar mx-auto mt-12 h-1.5 w-48 rounded-full md:mx-0"></div>
      </div>
    </div>
  </section>

  <div class="border-b border-ink/10 bg-cream-deep">
    <div class="mx-auto flex max-w-7xl flex-wrap items-center justify-center gap-x-8 gap-y-3 px-4 py-5 text-sm font-600 text-ink-soft lg:px-8">
      {t.common.credentials.map((c) => (
        <span class="inline-flex items-center gap-2"><Icon name="lucide:badge-check" class="h-4 w-4 text-copper" /> {c}</span>
      ))}
    </div>
  </div>

  <Section>
    <SectionHeading eyebrow={h.universEyebrow} title={h.universHeading} intro={h.universIntro} />
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {h.univers.map((u, i) => (
        <a href={L(universMeta[i].href)} class="group flex flex-col overflow-hidden rounded-card border border-ink/10 bg-cream-deep/40 transition-all hover:-translate-y-1 hover:shadow-xl">
          <div class="aspect-video overflow-hidden bg-ink/5">
            <img src={universMeta[i].img} width={universMeta[i].w} height={universMeta[i].h} alt={u.title} class:list={['h-full w-full transition-transform duration-500 group-hover:scale-105', universMeta[i].fit === 'contain' ? 'object-contain p-5' : universMeta[i].fit === 'cover-top' ? 'object-cover object-top' : 'object-cover']} loading="lazy" />
          </div>
          <div class="flex flex-1 flex-col p-6">
            <div class="flex items-center gap-2 text-copper"><Icon name={universMeta[i].icon} class="h-5 w-5" /><span class="text-xs font-700 uppercase tracking-widest">{u.sub}</span></div>
            <h3 class="mt-2 font-display text-2xl font-700">{u.title}</h3>
            <p class="mt-2 flex-1 text-ink-soft/85">{u.text}</p>
            <span class="mt-4 inline-flex items-center gap-1 font-700 text-rust transition-all group-hover:gap-2">{u.cta} →</span>
          </div>
        </a>
      ))}
    </div>
  </Section>

  <Section tone="cream-deep">
    <div class="grid items-center gap-10 lg:grid-cols-2">
      <div class="aspect-[4/3] overflow-hidden rounded-card"><img src="/images/hero-david.jpg" width="2400" height="1350" alt="David Lesage" class="h-full w-full object-cover object-top" loading="lazy" /></div>
      <div>
        <SectionHeading align="left" eyebrow={h.whyEyebrow} title={h.whyTitle} />
        <div class="mt-5 space-y-4 text-lg text-ink-soft/90"><p>{h.whyP1}</p><p>{h.whyP2}</p></div>
        <div class="mt-7"><Button href={L('/a-propos')} variant="ghost">{h.whyCta}</Button></div>
      </div>
    </div>
  </Section>

  <Section tone="ink">
    <div class="grid items-center gap-10 lg:grid-cols-2">
      <div>
        <p class="inline-flex items-center gap-2 rounded-full bg-rust/20 px-4 py-1.5 text-xs font-700 uppercase tracking-widest text-gold">{h.showroomBadge}</p>
        <h2 class="mt-5 font-display text-3xl font-700 leading-tight md:text-4xl">{h.showroomTitle}</h2>
        <p class="mt-5 text-lg text-cream/80">{h.showroomText}</p>
        <ul class="mt-6 space-y-3 text-cream/90">
          {h.showroomArgs.map((a) => <li class="flex gap-3"><Icon name="lucide:check" class="mt-1 h-5 w-5 shrink-0 text-gold" /> {a}</li>)}
        </ul>
        <div class="mt-8 flex flex-wrap gap-3">
          <Button href={L('/showroom')} variant="primary">{h.showroomCta1}</Button>
          <Button href={L('/showroom') + '#agenda'} variant="light">{h.showroomCta2}</Button>
        </div>
      </div>
      <div class="aspect-video overflow-hidden rounded-card">
        <video class="h-full w-full object-cover" autoplay muted loop playsinline poster="/images/localisation-showroom-poster.webp"><source src="/images/localisation-showroom.mp4" type="video/mp4" /></video>
      </div>
    </div>
  </Section>

  <Section id="communaute">
    <div class="rounded-card border border-ink/10 bg-cream-deep/50 p-8 text-center md:p-14">
      <SectionHeading eyebrow={h.communityEyebrow} title={h.communityTitle} intro={h.communityIntro} />
      <div class="mt-8 flex flex-col items-center gap-3">
        <a href={newsletterMailto(lang)} class="rounded-full bg-rust px-8 py-4 font-700 text-cream shadow-md transition-all duration-200 hover:-translate-y-0.5 hover:bg-copper">{h.communityButton}</a>
        <p class="text-sm text-ink-soft/70">{h.communityNote}</p>
      </div>
    </div>
  </Section>

  <Section tone="cream-deep">
    <SectionHeading eyebrow={h.proofEyebrow} title={h.proofTitle} intro={h.proofIntro} />
    <div class="mx-auto mt-10 grid max-w-5xl gap-5 md:grid-cols-3">
      {homeVideos.map((id, i) => (
        <figure class="m-0">
          <YouTube id={id} title={h.proofVideos[i]} />
          <figcaption class="mt-3 text-sm font-600 text-ink-soft/85">{h.proofVideos[i]}</figcaption>
        </figure>
      ))}
    </div>
    <div class="mt-8 text-center">
      <button type="button" data-video-list={playlistId} data-video-title={h.proofCta} class="inline-flex items-center justify-center gap-2 rounded-full border border-ink/20 px-6 py-3 text-sm font-700 text-ink transition-all duration-200 hover:-translate-y-0.5 hover:bg-ink/5">{h.proofCta}</button>
    </div>
  </Section>
  <VideoModal />
</Layout>
