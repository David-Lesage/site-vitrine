---
import { models, countries, woods, woodNames } from '@/data/neotone'
import { site } from '@/data/site'
import { getDict } from '@/i18n/dict'
import type { Lang } from '@/i18n/config'

interface Props {
  lang: Lang
}
const { lang } = Astro.props
const t = getDict(lang)
const c = t.data.calc

const modelLabels: Record<string, string> = { one: 'Neotone¹', mutant: 'Neotone¹ Mutant' }

// Données injectées côté client
const calcData = {
  models: Object.fromEntries(models.map((m) => [m.id, { label: modelLabels[m.id], woods: m.woods }])),
  woodLabels: Object.fromEntries(woods.map((w) => [w.key, woodNames[w.key][lang]])),
  countries: Object.fromEntries(countries.map((co) => [co.code, { name: co.name[lang], vat: co.vat, eu: co.eu, note: co.note ? co.note[lang] : '' }])),
  i18n: {
    discountLabel: c.discountLabel,
    vat: c.vat,
    finalTTC: c.finalTTC,
    finalIncluded: c.finalIncluded,
    finalShowroom: c.finalShowroom,
    finalB2B: c.finalB2B,
    finalB2BNote: c.finalB2BNote,
    finalExtUE: c.finalExtUE,
    finalExtUENote: c.finalExtUENote,
    b2bNote: c.b2bNote,
  },
}
---

<div class="overflow-hidden rounded-card border border-ink/10 bg-cream-deep/40 shadow-sm">
  <div class="grid lg:grid-cols-5">
    <!-- Contrôles -->
    <div class="space-y-8 p-6 lg:col-span-3 lg:p-8">
      <fieldset>
        <legend class="text-xs font-700 uppercase tracking-widest text-copper">{c.modeQuestion}</legend>
        <div class="mt-3 grid gap-3 sm:grid-cols-2" role="radiogroup" aria-label={c.modeQuestion}>
          <button type="button" class="calc-mode rounded-xl border-2 border-copper bg-copper/10 p-4 text-left" data-mode="online" aria-checked="true" role="radio">
            <span class="block font-700">{c.modeOnline}</span>
            <span class="block text-sm text-ink-soft/80">{c.modeOnlineSub}</span>
          </button>
          <button type="button" class="calc-mode rounded-xl border-2 border-ink/15 p-4 text-left" data-mode="showroom" aria-checked="false" role="radio">
            <span class="block font-700">{c.modeShowroom}</span>
            <span class="block text-sm text-ink-soft/80">{c.modeShowroomSub}</span>
          </button>
        </div>
      </fieldset>

      <fieldset>
        <legend class="text-xs font-700 uppercase tracking-widest text-copper">{c.step1}</legend>
        <div class="mt-3 grid gap-3 sm:grid-cols-2" role="radiogroup" aria-label={c.step1}>
          {models.map((m, i) => (
            <button type="button" class:list={['calc-model rounded-xl border-2 p-4 text-left', i === 0 ? 'border-copper bg-copper/10' : 'border-ink/15']} data-model={m.id} aria-checked={i === 0 ? 'true' : 'false'} role="radio">
              <span class="block font-display text-lg font-700">{modelLabels[m.id]}</span>
              <span class="block text-sm text-ink-soft/80">{t.data.modelNotes[m.id]}</span>
            </button>
          ))}
        </div>
      </fieldset>

      <fieldset>
        <legend class="text-xs font-700 uppercase tracking-widest text-copper">{c.step2}</legend>
        <div class="mt-3 flex flex-wrap gap-4" role="radiogroup" aria-label={c.step2}>
          {woods.map((w, i) => (
            <button type="button" class="calc-wood flex flex-col items-center gap-1.5" data-wood={w.key} aria-checked={i === 0 ? 'true' : 'false'} role="radio">
              <span class="calc-wood-disc"><img src={w.img} width="570" height="420" alt={woodNames[w.key][lang]} loading="lazy" /></span>
              <span class="text-xs font-600">{woodNames[w.key][lang]}</span>
            </button>
          ))}
        </div>
      </fieldset>

      <fieldset>
        <legend class="text-xs font-700 uppercase tracking-widest text-copper">{c.step3}</legend>
        <label class="sr-only" for="calc-country">{c.step3}</label>
        <select id="calc-country" class="mt-3 w-full rounded-xl border-2 border-ink/15 bg-cream px-4 py-3 font-600 focus:border-copper focus:outline-none">
          {countries.map((co) => (
            <option value={co.code}>{co.name[lang]}{co.eu ? ` — ${c.vatStd} ${co.vat.toString().replace('.', ',')} %` : ` — ${c.noVat}`}</option>
          ))}
        </select>
        <label class="mt-3 flex items-start gap-3 text-sm text-ink-soft/85">
          <input type="checkbox" id="calc-b2b" class="mt-1" />
          <span>{c.b2b}</span>
        </label>
      </fieldset>
    </div>

    <!-- Récapitulatif -->
    <div class="bg-ink p-6 text-cream lg:col-span-2 lg:p-8">
      <p class="text-xs font-700 uppercase tracking-widest text-gold">{c.recap}</p>
      <p id="calc-selection" class="mt-2 font-display text-xl font-700"></p>
      <dl class="mt-6 space-y-3 text-sm">
        <div class="flex justify-between gap-4"><dt class="text-cream/70">{c.basePrice}</dt><dd id="calc-base" class="font-600"></dd></div>
        <div class="flex justify-between gap-4"><dt id="calc-discount-label" class="text-cream/70"></dt><dd id="calc-discount" class="font-600 text-gold"></dd></div>
        <div class="flex justify-between gap-4 border-t border-cream/15 pt-3"><dt class="text-cream/70">{c.subtotal}</dt><dd id="calc-subtotal" class="font-600"></dd></div>
        <div id="calc-vat-wrap" class="flex justify-between gap-4"><dt id="calc-vat-label" class="text-cream/70"></dt><dd id="calc-vat" class="font-600"></dd></div>
      </dl>
      <div class="mt-6 border-t border-cream/15 pt-5">
        <p id="calc-final-label" class="text-xs font-600 uppercase tracking-widest text-gold"></p>
        <p id="calc-final" class="mt-1 font-display text-4xl font-700"></p>
        <p id="calc-final-note" class="mt-1 text-xs text-cream/60"></p>
      </div>
      <p class="mt-4 inline-flex items-center gap-2 rounded-lg bg-rust/20 px-3 py-2 text-sm text-gold">
        {c.savings} <span id="calc-savings" class="font-700"></span>
      </p>
      <p id="calc-extra-note" class="mt-4 text-xs leading-relaxed text-cream/55"></p>
      <a href={`mailto:${site.email}?subject=Neotone`} class="mt-6 block rounded-full bg-rust px-5 py-3 text-center font-700 text-cream transition-colors hover:bg-copper">
        {c.getCode}
      </a>
    </div>
  </div>
</div>

<script type="application/json" id="calc-data" set:html={JSON.stringify(calcData)}></script>

<script>
  const dataEl = document.getElementById('calc-data')
  if (dataEl) {
    const DATA = JSON.parse(dataEl.textContent || '{}')
    const L = DATA.i18n
    const state = { model: 'one', wood: 'frene', country: 'FR', b2b: false, mode: 'online' }
    const locale = document.documentElement.lang === 'en' ? 'en-GB' : 'fr-FR'

    const fmtEUR = (n: number) => new Intl.NumberFormat(locale, { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n) + ' €'
    const fmtVAT = (v: number) => (v === Math.floor(v) ? v + ' %' : v.toString().replace('.', ',') + ' %')
    const $ = (id: string) => document.getElementById(id)

    function compute() {
      const basePrice = DATA.models[state.model].woods[state.wood]
      const discountRate = state.mode === 'showroom' ? 0.07 : 0.05
      const discount = basePrice * discountRate
      const subtotalHT = basePrice - discount
      const country = DATA.countries[state.country]
      let vatRate = 0, vatAmount = 0, finalTTC = subtotalHT
      if (country.eu && !state.b2b) {
        vatRate = country.vat
        vatAmount = subtotalHT * (vatRate / 100)
        finalTTC = subtotalHT + vatAmount
      }
      const savings = country.eu && !state.b2b ? discount * (1 + vatRate / 100) : discount
      return { basePrice, discount, discountRate, subtotalHT, vatRate, vatAmount, finalTTC, savings, country }
    }

    function render() {
      const r = compute()
      $('calc-selection')!.textContent = `${DATA.models[state.model].label} — ${DATA.woodLabels[state.wood]}`
      $('calc-base')!.textContent = fmtEUR(r.basePrice)
      $('calc-discount-label')!.textContent = `${L.discountLabel} −${Math.round(r.discountRate * 100)} %`
      $('calc-discount')!.textContent = '− ' + fmtEUR(r.discount)
      $('calc-subtotal')!.textContent = fmtEUR(r.subtotalHT)

      const vatWrap = $('calc-vat-wrap')!
      if (r.country.eu && !state.b2b) {
        vatWrap.style.display = ''
        $('calc-vat-label')!.textContent = `${L.vat} ${r.country.name} ${fmtVAT(r.vatRate)}`
        $('calc-vat')!.textContent = fmtEUR(r.vatAmount)
        $('calc-final-label')!.textContent = L.finalTTC
        $('calc-final-note')!.textContent = L.finalIncluded
        $('calc-extra-note')!.innerHTML = ''
      } else if (state.b2b) {
        vatWrap.style.display = 'none'
        $('calc-final-label')!.textContent = L.finalB2B
        $('calc-final-note')!.textContent = L.finalB2BNote
        $('calc-extra-note')!.innerHTML = L.b2bNote
      } else {
        vatWrap.style.display = 'none'
        $('calc-final-label')!.textContent = L.finalExtUE
        $('calc-final-note')!.textContent = L.finalExtUENote
        $('calc-extra-note')!.innerHTML = r.country.note || ''
      }
      if (state.mode === 'showroom') $('calc-final-note')!.textContent = L.finalShowroom

      const finalEl = $('calc-final')!
      finalEl.classList.remove('price-update')
      void finalEl.offsetWidth
      finalEl.textContent = fmtEUR(r.finalTTC)
      finalEl.classList.add('price-update')
      $('calc-savings')!.textContent = fmtEUR(r.savings)
    }

    function bindGroup(selector: string, key: 'model' | 'wood' | 'mode', attr: string) {
      document.querySelectorAll<HTMLButtonElement>(selector).forEach((btn) => {
        btn.addEventListener('click', () => {
          document.querySelectorAll<HTMLButtonElement>(selector).forEach((b) => {
            b.classList.remove('border-copper', 'bg-copper/10')
            b.classList.add('border-ink/15')
            b.setAttribute('aria-checked', 'false')
          })
          btn.classList.add('border-copper', 'bg-copper/10')
          btn.classList.remove('border-ink/15')
          btn.setAttribute('aria-checked', 'true')
          ;(state as any)[key] = btn.dataset[attr]
          render()
        })
      })
    }
    bindGroup('.calc-mode', 'mode', 'mode')
    bindGroup('.calc-model', 'model', 'model')
    bindGroup('.calc-wood', 'wood', 'wood')

    ;($('calc-country') as HTMLSelectElement).addEventListener('change', (e) => { state.country = (e.target as HTMLSelectElement).value; render() })
    ;($('calc-b2b') as HTMLInputElement).addEventListener('change', (e) => { state.b2b = (e.target as HTMLInputElement).checked; render() })
    render()
  }
</script>
