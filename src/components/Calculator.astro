---
import { models, countries, woods, woodLabels } from '@/data/neotone'
import { site } from '@/data/site'

// Données injectées côté client
const calcData = {
  models: Object.fromEntries(models.map((m) => [m.id, { label: m.label, woods: m.woods }])),
  woodLabels,
  countries: Object.fromEntries(countries.map((c) => [c.code, { name: c.name, vat: c.vat, eu: c.eu, note: c.note || '' }])),
}
---

<div class="overflow-hidden rounded-card border border-ink/10 bg-cream-deep/40 shadow-sm">
  <div class="grid lg:grid-cols-5">
    <!-- Contrôles -->
    <div class="space-y-8 p-6 lg:col-span-3 lg:p-8">
      <!-- Mode d'achat -->
      <fieldset>
        <legend class="text-xs font-700 uppercase tracking-widest text-copper">Comment veux-tu recevoir ton Neotone ?</legend>
        <div class="mt-3 grid gap-3 sm:grid-cols-2" role="radiogroup" aria-label="Mode d'achat">
          <button type="button" class="calc-mode rounded-xl border-2 border-copper bg-copper/10 p-4 text-left" data-mode="online" aria-checked="true" role="radio">
            <span class="block font-700">📦 Je me fais livrer</span>
            <span class="block text-sm text-ink-soft/80">Livraison mondiale incluse · remise 5 %</span>
          </button>
          <button type="button" class="calc-mode rounded-xl border-2 border-ink/15 p-4 text-left" data-mode="showroom" aria-checked="false" role="radio">
            <span class="block font-700">🏠 Je viens au showroom ★</span>
            <span class="block text-sm text-ink-soft/80">Paris 20ᵉ · remise 7 % · sans délai</span>
          </button>
        </div>
      </fieldset>

      <!-- Modèle -->
      <fieldset>
        <legend class="text-xs font-700 uppercase tracking-widest text-copper">1 · Choisis ton modèle</legend>
        <div class="mt-3 grid gap-3 sm:grid-cols-2" role="radiogroup" aria-label="Modèle">
          {models.map((m, i) => (
            <button type="button" class:list={['calc-model rounded-xl border-2 p-4 text-left', i === 0 ? 'border-copper bg-copper/10' : 'border-ink/15']} data-model={m.id} aria-checked={i === 0 ? 'true' : 'false'} role="radio">
              <span class="block font-display text-lg font-700">{m.label}</span>
              <span class="block text-sm text-ink-soft/80">{m.notesLabel}</span>
            </button>
          ))}
        </div>
      </fieldset>

      <!-- Bois -->
      <fieldset>
        <legend class="text-xs font-700 uppercase tracking-widest text-copper">2 · Choisis ton bois</legend>
        <div class="mt-3 flex flex-wrap gap-2" role="radiogroup" aria-label="Bois">
          {woods.map((w, i) => (
            <button type="button" class:list={['calc-wood rounded-full border-2 px-4 py-2 text-sm font-600', i === 0 ? 'border-copper bg-copper/10' : 'border-ink/15']} data-wood={w.key} aria-checked={i === 0 ? 'true' : 'false'} role="radio">
              {woodLabels[w.key]}
            </button>
          ))}
        </div>
      </fieldset>

      <!-- Pays -->
      <fieldset>
        <legend class="text-xs font-700 uppercase tracking-widest text-copper">3 · Ton pays de livraison</legend>
        <label class="sr-only" for="calc-country">Pays</label>
        <select id="calc-country" class="mt-3 w-full rounded-xl border-2 border-ink/15 bg-cream px-4 py-3 font-600 focus:border-copper focus:outline-none">
          {countries.map((c) => (
            <option value={c.code}>{c.name}{c.eu ? ` — TVA ${c.vat.toString().replace('.', ',')} %` : ' — sans TVA UE'}</option>
          ))}
        </select>
        <label class="mt-3 flex items-start gap-3 text-sm text-ink-soft/85">
          <input type="checkbox" id="calc-b2b" class="mt-1" />
          <span>J’ai un numéro de TVA intracommunautaire (B2B) — la TVA est récupérable (autoliquidation), tu paies le prix HT.</span>
        </label>
      </fieldset>
    </div>

    <!-- Récapitulatif -->
    <div class="bg-ink p-6 text-cream lg:col-span-2 lg:p-8">
      <p class="text-xs font-700 uppercase tracking-widest text-gold">Récapitulatif</p>
      <p id="calc-selection" class="mt-2 font-display text-xl font-700"></p>
      <dl class="mt-6 space-y-3 text-sm">
        <div class="flex justify-between gap-4"><dt class="text-cream/70">Prix public HT (envoi compris)</dt><dd id="calc-base" class="font-600"></dd></div>
        <div class="flex justify-between gap-4"><dt id="calc-discount-label" class="text-cream/70"></dt><dd id="calc-discount" class="font-600 text-gold"></dd></div>
        <div class="flex justify-between gap-4 border-t border-cream/15 pt-3"><dt class="text-cream/70">Sous-total HT</dt><dd id="calc-subtotal" class="font-600"></dd></div>
        <div id="calc-vat-wrap" class="flex justify-between gap-4"><dt id="calc-vat-label" class="text-cream/70"></dt><dd id="calc-vat" class="font-600"></dd></div>
      </dl>
      <div class="mt-6 border-t border-cream/15 pt-5">
        <p id="calc-final-label" class="text-xs font-600 uppercase tracking-widest text-gold"></p>
        <p id="calc-final" class="mt-1 font-display text-4xl font-700"></p>
        <p id="calc-final-note" class="mt-1 text-xs text-cream/60"></p>
      </div>
      <p class="mt-4 inline-flex items-center gap-2 rounded-lg bg-rust/20 px-3 py-2 text-sm text-gold">
        Tu économises <span id="calc-savings" class="font-700"></span>
      </p>
      <p id="calc-extra-note" class="mt-4 text-xs leading-relaxed text-cream/55"></p>
      <a href={`mailto:${site.emailNeotone}?subject=Mon%20code%20de%20remise%20Neotone`} class="mt-6 block rounded-full bg-rust px-5 py-3 text-center font-700 text-cream transition-colors hover:bg-copper">
        Obtenir mon code de remise
      </a>
    </div>
  </div>
</div>

<script type="application/json" id="calc-data" set:html={JSON.stringify(calcData)}></script>

<script>
  const dataEl = document.getElementById('calc-data')
  if (dataEl) {
    const DATA = JSON.parse(dataEl.textContent || '{}')
    const state = { model: 'one', wood: 'frene', country: 'FR', b2b: false, mode: 'online' }

    const fmtEUR = (n: number) => new Intl.NumberFormat('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n) + ' €'
    const fmtVAT = (v: number) => (v === Math.floor(v) ? v + ' %' : v.toString().replace('.', ',') + ' %')
    const $ = (id: string) => document.getElementById(id)

    function compute() {
      const basePrice = DATA.models[state.model].woods[state.wood]
      const discountRate = state.mode === 'showroom' ? 0.07 : 0.05
      const discount = basePrice * discountRate
      const subtotalHT = basePrice - discount
      const country = DATA.countries[state.country]
      let vatRate = 0, vatAmount = 0, finalTTC = subtotalHT
      if (country.eu && !state.b2b) {
        vatRate = country.vat
        vatAmount = subtotalHT * (vatRate / 100)
        finalTTC = subtotalHT + vatAmount
      }
      const savings = country.eu && !state.b2b ? discount * (1 + vatRate / 100) : discount
      return { basePrice, discount, discountRate, subtotalHT, vatRate, vatAmount, finalTTC, savings, country }
    }

    function render() {
      const r = compute()
      $('calc-selection')!.textContent = `${DATA.models[state.model].label} — ${DATA.woodLabels[state.wood]}`
      $('calc-base')!.textContent = fmtEUR(r.basePrice)
      $('calc-discount-label')!.textContent = `Remise ambassadeur −${Math.round(r.discountRate * 100)} %`
      $('calc-discount')!.textContent = '− ' + fmtEUR(r.discount)
      $('calc-subtotal')!.textContent = fmtEUR(r.subtotalHT)

      const vatWrap = $('calc-vat-wrap')!
      if (r.country.eu && !state.b2b) {
        vatWrap.style.display = ''
        $('calc-vat-label')!.textContent = `TVA ${r.country.name} ${fmtVAT(r.vatRate)}`
        $('calc-vat')!.textContent = fmtEUR(r.vatAmount)
        $('calc-final-label')!.textContent = 'Prix final TTC à payer'
        $('calc-final-note')!.textContent = 'Livraison mondiale incluse · Garantie 6 ans'
        $('calc-extra-note')!.innerHTML = ''
      } else if (state.b2b) {
        vatWrap.style.display = 'none'
        $('calc-final-label')!.textContent = 'Prix HT à payer (autoliquidation)'
        $('calc-final-note')!.textContent = 'TVA récupérable · n° de TVA intracommunautaire requis'
        $('calc-extra-note')!.innerHTML = 'Autoliquidation de la TVA : tu déclares et récupères la TVA dans ton pays. Numéro de TVA intracommunautaire valide requis.'
      } else {
        vatWrap.style.display = 'none'
        $('calc-final-label')!.textContent = 'Prix HT à payer · hors UE'
        $('calc-final-note')!.textContent = 'Sans TVA UE · frais de douane locaux à ta charge'
        $('calc-extra-note')!.innerHTML = r.country.note || ''
      }
      if (state.mode === 'showroom') {
        $('calc-final-note')!.textContent = 'Retrait au showroom · Paris 20ᵉ · aucun délai, aucun frais d’envoi'
      }

      const finalEl = $('calc-final')!
      finalEl.classList.remove('price-update')
      void finalEl.offsetWidth
      finalEl.textContent = fmtEUR(r.finalTTC)
      finalEl.classList.add('price-update')
      $('calc-savings')!.textContent = fmtEUR(r.savings)
    }

    function bindGroup(selector: string, key: 'model' | 'wood' | 'mode', attr: string) {
      document.querySelectorAll<HTMLButtonElement>(selector).forEach((btn) => {
        btn.addEventListener('click', () => {
          document.querySelectorAll<HTMLButtonElement>(selector).forEach((b) => {
            b.classList.remove('border-copper', 'bg-copper/10')
            b.classList.add('border-ink/15')
            b.setAttribute('aria-checked', 'false')
          })
          btn.classList.add('border-copper', 'bg-copper/10')
          btn.classList.remove('border-ink/15')
          btn.setAttribute('aria-checked', 'true')
          ;(state as any)[key] = btn.dataset[attr]
          render()
        })
      })
    }
    bindGroup('.calc-mode', 'mode', 'mode')
    bindGroup('.calc-model', 'model', 'model')
    bindGroup('.calc-wood', 'wood', 'wood')

    ;($('calc-country') as HTMLSelectElement).addEventListener('change', (e) => {
      state.country = (e.target as HTMLSelectElement).value
      render()
    })
    ;($('calc-b2b') as HTMLInputElement).addEventListener('change', (e) => {
      state.b2b = (e.target as HTMLInputElement).checked
      render()
    })

    render()
  }
</script>
