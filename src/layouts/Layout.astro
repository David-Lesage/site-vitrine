---
import '@/styles/global.css'
import SEO from '@/components/SEO.astro'
import Header from '@/components/Header.astro'
import Footer from '@/components/Footer.astro'
import { getLang } from '@/i18n/utils'
import { getDict } from '@/i18n/dict'
import { htmlLang } from '@/i18n/config'

interface Props {
  title?: string
  description?: string
  image?: string
  ldJSON?: unknown | unknown[]
  ogType?: string
  keywords?: string
  // Pages traduites hors dictionnaire principal (ex. /zh/micro-muling) :
  // force l'attribut lang du <html> sans toucher au routage i18n.
  htmlLangOverride?: string
}

const { title, description, image, ldJSON, ogType, keywords, htmlLangOverride } = Astro.props
const lang = getLang(Astro.url)
const t = getDict(lang)

const snipcartKey = import.meta.env.PUBLIC_SNIPCART_KEY || ''
---

<!doctype html>
<html lang={htmlLangOverride || htmlLang[lang]}>
  <head>
    <SEO title={title} description={description} image={image} ldJSON={ldJSON} ogType={ogType} keywords={keywords} lang={lang} />
    <script is:inline>
      // Détection de la langue du visiteur, avec garde-fous :
      // — jamais si l'utilisateur a déjà choisi une langue (localStorage) ;
      // — jamais deux fois dans la même session (anti-boucle) ;
      // — jamais depuis une page déjà localisée (/en, /zh) ;
      // — les francophones restent sur la version française (par défaut).
      ;(function () {
        try {
          if (localStorage.getItem('pref-lang')) return
          if (sessionStorage.getItem('lang-auto')) return
          var path = location.pathname
          if (/^\/(en|zh)(\/|$)/.test(path)) return
          var nav = navigator.languages && navigator.languages.length ? navigator.languages[0] : navigator.language
          var code = (nav || '').toLowerCase()
          if (!code || code.indexOf('fr') === 0) return
          // Le chinois n'existe que sur la page Muling ; ailleurs → anglais.
          var zhPages = ['/micro-muling']
          var target =
            code.indexOf('zh') === 0 && zhPages.indexOf(path.replace(/\/$/, '')) !== -1
              ? '/zh' + path.replace(/\/$/, '')
              : '/en' + (path === '/' ? '' : path)
          sessionStorage.setItem('lang-auto', '1')
          location.replace(target)
        } catch (e) {}
      })()
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Manrope:wght@400;500;600;700;800&display=swap"
    />
    {snipcartKey && <link rel="preconnect" href="https://app.snipcart.com" />}
    {snipcartKey && <link rel="stylesheet" href="https://cdn.snipcart.com/themes/v3.7.1/default/snipcart.css" />}
  </head>
  <body class="flex min-h-screen flex-col">
    <a href="#main" class="skip-link">{t.common.skip}</a>
    <Header lang={lang} />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />

    {snipcartKey && (
      <>
        <div hidden id="snipcart" data-api-key={snipcartKey} data-config-modal-style="side"></div>
        <script is:inline src="https://cdn.snipcart.com/themes/v3.7.1/default/snipcart.js" defer></script>
      </>
    )}
  </body>
</html>
